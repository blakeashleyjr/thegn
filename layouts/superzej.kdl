// layouts/superzej.kdl — the base layout for the single superzej session.
//
// Applied on session cold-start (`zellij --layout superzej attach --create`).
// The session is rooted at the first repo, so the home tab's pane resolves it.
//
// Every tab is SELF-CONTAINED: it explicitly wraps its terminal with the left
// sidebar, the centered branch tab-strip, and the right diff/PR panel (all WASM
// plugins). We deliberately do NOT use a `default_tab_template`: a tab spawned
// via `new-tab --layout home-tab|worktree-tab` does not reliably inherit the
// session template (zellij-org/zellij#4646), which left opened repos as a bare
// full-screen terminal. So `home-tab.kdl` / `worktree-tab.kdl` repeat this same
// wrapper — keep the three in sync.
//
// Chrome is deliberately minimal: no bottom status/hint bar (superzej is a fixed
// Alt-leader scheme), and the tab strip is a custom plugin nested inside the
// middle column so it sits indented over the terminal.
//
// NOTE: zellij does not allow a `keybinds` node inside a layout — keybinds live
// in the managed config (config/zellij.kdl -> ~/.superzej/zellij.kdl), which
// `superzej` starts zellij with via `--config`.
layout {
    tab name="home" focus=true {
        pane split_direction="horizontal" {
            pane split_direction="vertical" {
                // 12% ~= 20 cols on a 166-col terminal; the plugin snaps itself to
                // exactly 20 on load. Percent (not fixed) so hide/show and
                // user resizes work — zellij refuses to resize fixed panes.
                pane size="12%" borderless=true {
                    plugin location="file:~/.local/share/superzej/sidebar.wasm"
                }
                pane {
                    pane size=1 borderless=true {
                        plugin location="file:~/.local/share/superzej/tabbar.wasm"
                    }
                    pane focus=true {
                        command "superzej"
                        args "status"
                    }
                }
                // 27% ~= 44 cols on a 166-col terminal; the plugin snaps itself to exact width on load.
                pane size="27%" borderless=true {
                    plugin location="file:~/.local/share/superzej/panel.wasm"
                }
            }
            pane size=1 borderless=true {
                plugin location="file:~/.local/share/superzej/statusbar.wasm"
            }
        }
    }

    // ── Alt+[ / Alt+] arrangements for the center terminals ────────────────
    // The chrome template pins the four plugin surfaces; `children` is the
    // center column under the tabbar. All variants need ≥2 center terminals
    // (min_panes counts every pane: 4 plugins + 2 terminals = 6) so that with
    // a single terminal NO variant matches and the sidebar/panel toggles'
    // next_swap_layout() restore keeps snapping to the base template.
    // "vertical" mirrors the base arrangement — keep it FIRST so any swap
    // entry lands on the familiar look. Keep this block in sync across
    // superzej.kdl / home-tab.kdl / worktree-tab.kdl / worktree-tab-extra.kdl.
    tab_template name="chrome" {
        pane split_direction="horizontal" {
            pane split_direction="vertical" {
                pane size="12%" borderless=true {
                    plugin location="file:~/.local/share/superzej/sidebar.wasm"
                }
                pane {
                    pane size=1 borderless=true {
                        plugin location="file:~/.local/share/superzej/tabbar.wasm"
                    }
                    children
                }
                pane size="27%" borderless=true {
                    plugin location="file:~/.local/share/superzej/panel.wasm"
                }
            }
            pane size=1 borderless=true {
                plugin location="file:~/.local/share/superzej/statusbar.wasm"
            }
        }
    }
    swap_tiled_layout name="vertical" {
        chrome min_panes=6 {
            pane split_direction="horizontal" {
                children
            }
        }
    }
    swap_tiled_layout name="horizontal" {
        chrome min_panes=6 {
            pane split_direction="vertical" {
                children
            }
        }
    }
    swap_tiled_layout name="stacked" {
        chrome min_panes=6 {
            pane stacked=true {
                children
            }
        }
    }
}
