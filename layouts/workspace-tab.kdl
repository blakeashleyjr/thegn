// layouts/workspace-tab.kdl — tab template applied by `superzej new-workspace`.
//
// The tab's cwd (repo root) is injected via `new-tab --cwd`, so the first pane
// inherits it. That pane creates the workspace's first worktree and runs the
// agent picker in place (--in-place => no leftover exited pane).
layout {
    tab {
        pane {
            command "superzej"
            args "new-pane" "--in-place"
        }
    }
}
