// layouts/worktree-tab-restore.kdl — a worktree tab recreated on session restart
// by `superzej restore-session` (`new-tab --cwd <worktree> --layout
// worktree-tab-restore`).
//
// Identical to worktree-tab.kdl EXCEPT the center pane runs `pick-agent` with
// `--resume`, so it relaunches the worktree's previously-recorded agent without
// prompting (falling back to the picker if none was recorded). Keep the chrome +
// swap-layout block in sync with superzej.kdl / home-tab.kdl / worktree-tab.kdl.
layout {
    pane split_direction="horizontal" {
        pane size=1 borderless=true {
            plugin location="file:~/.local/share/superzej/tabbar.wasm"
        }
        pane split_direction="vertical" {
            pane size="12%" name="" {
                plugin location="file:~/.local/share/superzej/sidebar.wasm"
            }
            pane focus=true {
                command "superzej"
                args "pick-agent" "--in-place" "--resume"
            }
            pane size="27%" name="" {
                plugin location="file:~/.local/share/superzej/panel.wasm"
            }
        }
        pane size=1 borderless=true {
            plugin location="file:~/.local/share/superzej/statusbar.wasm"
        }
    }

    tab_template name="chrome" {
        pane split_direction="horizontal" {
            pane size=1 borderless=true {
                plugin location="file:~/.local/share/superzej/tabbar.wasm"
            }
            pane split_direction="vertical" {
                pane size="12%" name="" {
                    plugin location="file:~/.local/share/superzej/sidebar.wasm"
                }
                children
                pane size="27%" name="" {
                    plugin location="file:~/.local/share/superzej/panel.wasm"
                }
            }
            pane size=1 borderless=true {
                plugin location="file:~/.local/share/superzej/statusbar.wasm"
            }
        }
    }
    swap_tiled_layout name="vertical" {
        chrome min_panes=6 {
            pane split_direction="horizontal" {
                children
            }
        }
    }
    swap_tiled_layout name="horizontal" {
        chrome min_panes=6 {
            pane split_direction="vertical" {
                children
            }
        }
    }
    swap_tiled_layout name="stacked" {
        chrome min_panes=6 {
            pane stacked=true {
                children
            }
        }
    }
}
