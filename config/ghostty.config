# Ghostty profile for running thegn (`just start-term`): tuned for a
# compositor that owns its own chrome, scrollback, and selection — and for the
# lowest input-to-present latency while profiling the host.
#
# Loaded hermetically: `just start-term` passes this via --config-file with
# --config-default-files=false, so none of your personal ghostty config leaks in.

# --- window: thegn draws its own bars, so strip all native chrome ---
window-decoration = false
gtk-titlebar = false
window-padding-x = 0
window-padding-y = 4
window-padding-balance = false
maximize = true
# This is a throwaway dev/profiling window — never restore its geometry/tabs.
window-save-state = never
# The host owns its own resize feedback; ghostty's size overlay would flash
# over the chrome on every reflow.
resize-overlay = never
confirm-close-surface = false

# --- dedicated OS process per launch (critical for the profiling workflow) ---
# Force a fresh, isolated process rather than grafting a tab onto an already
# running ghostty, so the pidfile, `pgrep -n thegn`, and the SIGUSR2 flamegraph
# drill all target THIS instance.
gtk-single-instance = false

# --- performance / latency ---
# Trade occasional tearing for the lowest input-to-present latency. This window
# exists to profile thegn, not to look pretty (Linux/GTK may treat this as a
# hint; harmless where unsupported).
window-vsync = false
# The host owns scrollback (per-pane, Shift+PgUp / wheel); an outer history
# buffer just wastes memory and double-pages the same content.
scrollback-limit = 0
# The compositor owns hover/selection — skip ghostty's URL-detection regex pass
# on every screen update.
link-url = false
# We exec our own wrapper straight into thegn; ghostty's shell-integration
# injection adds overhead and fights the compositor for control sequences.
shell-integration = none

# --- font: match the daily-driver setup; nerd glyphs back the bar icons ---
font-family = FiraCode Nerd Font
font-size = 13
# A touch of extra line height keeps the chrome airy (≈ the old alacritty
# offset.y = 2 at size 13).
adjust-cell-height = 12%

# --- cursor / mouse ---
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

# --- color: match the storm-blue chrome so resize flashes blend in ---
background = 14161f
foreground = e0e4f0
background-opacity = 1.0

# TERM is left at ghostty's native `xterm-ghostty`, which the host's wire layer
# recognises for undercurl support — a strict upgrade over the old alacritty
# profile's forced xterm-256color.
