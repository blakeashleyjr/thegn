# The thegn base sandbox image — Containerfile fallback. The canonical build
# is nix (`nix/sandbox-image.nix`, `just image-build`); this exists for the
# RemoteBuild delivery strategy (a host with no route to receive the image
# builds it locally) and for users without nix. Content parity is best-effort:
# same user model (uid-1000 `thegn`), nix + direnv + rustup, populated /nix.
#
#   podman build -t localhost/thegn/base:dev -f config/sandbox-image/Containerfile .

FROM docker.io/library/debian:bookworm-slim

LABEL thegn.managed="true" \
      thegn.image.role="base"

RUN apt-get update \
 && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      ca-certificates curl git openssh-client xz-utils sudo zsh dtach rsync \
      procps \
 && rm -rf /var/lib/apt/lists/*

# uid-1000 user matching `--userns keep-id`; owns /nix so single-user nix and
# the copy-up volume seed both work.
RUN useradd -m -u 1000 -s /bin/bash thegn \
 && mkdir -p /nix /workspace \
 && chown -R thegn:thegn /nix /workspace

USER thegn
ENV HOME=/home/thegn \
    USER=thegn \
    PATH=/home/thegn/.nix-profile/bin:/home/thegn/.cargo/bin:/usr/local/bin:/usr/bin:/bin

# Determinate installer, single-user (`--init none`: containers have no init),
# flakes on, sig checks relaxed to match the provisioner's substitution model.
RUN curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix \
      | sh -s -- install linux --init none --no-confirm --extra-conf \
        "experimental-features = nix-command flakes" --extra-conf "require-sigs = false" \
 || curl -L https://nixos.org/nix/install | sh -s -- --no-daemon

# direnv + devenv + node + Claude Code + rustup with a warmed stable toolchain
# (the cargo registry index lands in ~/.cargo — the seed for the thegn-cargo
# warm volume). devenv/node/claude are baked so a container on a REMOTE host has
# the toolchain without a per-worktree install (the remote-OCI worktree path
# can't push the host's nix closure).
RUN . /home/thegn/.nix-profile/etc/profile.d/nix.sh 2>/dev/null || true; \
    nix profile install nixpkgs#direnv nixpkgs#nix-direnv \
      nixpkgs#devenv nixpkgs#nodejs nixpkgs#claude-code || true
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
      | sh -s -- -y --default-toolchain stable --profile minimal

WORKDIR /workspace
CMD ["/bin/bash", "-l"]
