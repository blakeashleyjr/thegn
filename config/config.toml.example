# superzej config — copy to ~/.config/superzej/config.toml and edit.
# All keys are optional (sane defaults apply). Home-manager users get this
# generated automatically from programs.superzej.

# Where worktrees live (grouped per repo) and where remote URLs are cloned.
worktrees_dir = "~/.superzej/worktrees"
workspaces_dir = "~/code"

# Roots scanned by the workspace repo picker (new-workspace / bare `sj`).
# Defaults to [workspaces_dir] if omitted.
repo_roots = ["~/code", "~/src"]
repo_scan_depth = 5

# Base ref for new worktrees: "auto" = current branch, else the repo default.
base_branch = "auto"
window_margin = 0
branch_prefix = "sz/"

# Picker UI: "auto" | "gum" | "fzf" | "select"
picker = "auto"

# Worktree location: "global" | "in_repo" (<repo>/.worktrees)
worktree_mode = "global"

# Auto branch naming: "words" (sz/brisk-otter) | "numbered" (sz/pane-1)
name_scheme = "words"

# Remove the worktree automatically when its pane closes.
auto_remove_worktree = false
# Ask before destructive worktree actions (sidebar delete-from-disk).
confirm_delete = true

# ── Overriding any setting at runtime ─────────────────────────────────────────
# Precedence (low → high): built-in defaults < this file < SUPERZEJ_* env vars
#   < CLI flags. Override any key for one run with SUPERZEJ_<SECTION>_<KEY>, e.g.
#     SUPERZEJ_PICKER=fzf        SUPERZEJ_SANDBOX_BACKEND=docker
#     SUPERZEJ_LOG_LEVEL=debug   SUPERZEJ_PR_TTL=10
# `superzej config show` prints the effective merged config; `superzej config
# get <dotted.key>` prints one value; `superzej config validate` checks it.

[ui]
# UI language: a BCP-47 code (e.g. "en-US", "ja-JP") or "auto" to detect.
language = "auto"
# Ask before deleting a workspace (Alt+Shift+X, or the sidebar "Remove
# workspace" action — both share one modal). The confirm modal pre-selects
# "delete worktrees from disk" (a "keep files" choice is offered too). Set false
# to skip the prompt and delete the worktree dirs from disk immediately.
confirm_delete_workspace = true
# Whether to display the full word for the mode chip (e.g., "Normal" instead of "N").
full_mode_chip = true

# Visual tuning. The focus accent recolors every superzej surface (plugins,
# pickers, dashboard). `focus_border` frames whatever owns focus — the focused
# pane's border ring, the active tab chip, the active worktree row, and the
# focused chrome edge. Unfocused frames use `colors.border`.
[theme]
# Named palette preset: "prism" (default), "storm", "light", "abyss", "ember",
# "aurora". Cycle live with Ctrl+Alt+t; [theme.colors] / [theme.hues]
# overrides apply on top.
preset = "prism"
accent = "#6ee7d8"
focus_border = "#6ee7d8"
# Horizontal breathing room (cells) between a pane's frame and its content.
pane_padding = 0
# Curly underlines (conflict squiggles): "auto" sniffs the terminal
# ($TERM / $TERM_PROGRAM / $VTE_VERSION); "on" / "off" force it. Unsupported
# terminals degrade to a single underline.
undercurl = "auto"
# Color fidelity. "auto" sniffs the terminal (COLORTERM / $TERM / WT_SESSION /
# NO_COLOR) and degrades truecolor -> 256 -> 16 -> mono as needed; pin a level
# with "truecolor", "256", "16", or "none"/"mono". The NO_COLOR env var forces
# "none" unless you set an explicit value here. (env: SUPERZEJ_THEME_COLOR)
color = "auto"
# Glyph fidelity for chrome (box drawing, status dots, arrows, the logotype).
# "auto" sniffs the locale (UTF-8?) and terminal; "unicode" forces the rounded
# Unicode look; "ascii" forces 7-bit fallbacks (+ - | * o ^ v) for bare
# terminals / fonts without box-drawing glyphs. Run `superzej doctor` to see
# what your terminal resolves to. (env: SUPERZEJ_THEME_GLYPHS)
glyphs = "auto"

# Optional: override any chrome surface/text color (all "#rrggbb"; unset keys
# keep the preset's palette). Invalid hex warns and keeps the default.
[theme.colors]
# bg0 = "#0b0e16"       # deepest background (sidebar)
# bg1 = "#10141f"       # bars / surfaces (tabbar, statusbar, panel)
# panel = "#151a28"     # panel lists
# panel2 = "#1a2031"    # selection / hover
# raise = "#222942"     # raised (context menus)
# border = "#6f788e"    # pane/edge frame lines
# text = "#edf0f8"      # primary text
# dim = "#aab1c5"       # secondary text
# faint = "#7a8197"     # tertiary / labels
# ghost = "#6f788e"     # connectors / disabled (faintest readable tier, ~3:1+)
# ghost2 = "#677084"    # structural glyphs (below ghost)
# ghost3 = "#60687b"    # deepest structural fg (rules, bar tracks)
# shadow_bg = "#05070c" # layer shadow cell background
# shadow_fg = "#1c2233" # layer shadow cell foreground
# chip_fg = "#0b0e16"   # text inside inverse chips (defaults to bg0)
# activity_active = "#edf0f8"   # sidebar dot: agent/worktree working (white)
# activity_waiting = "#ef6f6f"  # sidebar dot: agent waiting for your input (red)

# Optional: override the eight semantic hues (identity + status colors).
# Unset keys keep the preset's hues; legacy presets default to the prism set
# ("light" ships darker, paper-legible hues).
[theme.hues]
# teal = "#6ee7d8"
# magenta = "#ef8fc4"
# purple = "#b69cf2"
# green = "#7fdca0"
# amber = "#e6c264"
# red = "#ef6f6f"
# blue = "#7fb4ec"
# orange = "#f09d6a"

# Resource managers opened from the top-bar stats widget: highlight a stat with
# Super+Alt+Up, cycle CPU/MEM/Net/GPU with ←/→, press Enter to embed it as a pane.
# `system` backs the CPU and MEM segments; `gpu` backs the GPU segment.
[monitor]
system = "btm"   # CPU/RAM monitor (ClementTsang/bottom); e.g. "htop", "btop"
gpu = "nvtop"    # GPU monitor

# The customizable widget bars framing the workspace. Each slot is an ordered
# list of widget ids; unknown ids are skipped. Top-bar widgets: "brand"
# (superzej + version), "cpu", "mem", "disk" (free space on the worktrees' fs,
# color-coded; see [stats]), "gpu" (NVIDIA only; hidden if absent), "net",
# "date", "clock". Bottom-bar widgets: "keyhints" (context-dependent keybinds
# for the focused zone), "pr" (forge + PR number, state-colored), "tests"
# (✓pass ✗fail rollup of the last test run; green all-pass, red on failure;
# hidden until a run), "loc" (tokei line count), "disk" (the active worktree's
# size, incl. target/), "status" (transient messages).
[bars]
top_left = ["brand"]
# Widgets: cpu, mem, disk (free %), gpu, temp (CPU °C), net, swap, freq (CPU
# GHz), load (1-min load avg, unix only), uptime, battery, date, clock.
top_right = ["cpu", "mem", "disk", "gpu", "temp", "net", "battery", "date", "clock"]
bottom_left = ["keyhints"]
bottom_right = ["pr", "tests", "loc", "disk", "status"]   # "loc"=tokei line count; "disk"=worktree size
# chrono format strings for the date/clock widgets.
date_format = "%a %b %-d"
clock_format = "%H:%M"

# Top-bar stats widget: icons and refresh rate for CPU/RAM/Network/GPU display.
# Icons can be text ("CPU") or unicode symbols ("⚡"). GPU shows only if detected.
[stats]
refresh_secs = 2           # Polling interval in seconds
# Icons default to single-width Nerd Font glyphs; set plain text if your font
# lacks them. Use single-width PUA glyphs (U+E000–U+F8FF, e.g. nf-fa-*) only —
# the plane-15 Material Design set (nf-md-*, U+F0000+) advances two cells and
# leaves a gap between the icon and its value.
# cpu_icon = "CPU"
# mem_icon = "MEM"
# net_icon = "NET"
# gpu_icon = "GPU"              # shows only if a GPU is detected
# temp_icon = "TMP"             # CPU/package temperature
# swap_icon = "SWP"             # swap usage
# freq_icon = "FRQ"             # CPU frequency
# load_icon = "LD"              # load average (unix)
# uptime_icon = "UP"            # uptime
# battery_icon = "BAT"          # discharging icon
# battery_charging_icon = "CHG" # shown while charging / on AC
battery_warn = 25               # red at/below this percent
# disk_icon = "DSK"             # icon for the "disk" free-space widget
disk_free_warn = 15             # disk widget turns amber at/below this free %
disk_free_critical = 5          # disk widget turns red at/below this free %
# disk_path = "~/projects"      # fs the disk widget measures; "" = worktrees_dir's fs
refresh_rates = [1, 2, 5, 10]  # Click the top-right stats block to cycle

# Prometheus scrape targets for the sidebar METRICS section. superzej scrapes
# each /metrics endpoint directly; no Prometheus server is required. Values are
# filtered by the allowlist below before reaching the UI.
[metrics]
interval_secs = 5        # Scrape interval in seconds (SUPERZEJ_METRICS_INTERVAL_SECS)
timeout_ms = 500         # Request timeout in milliseconds
max_body_bytes = 1048576 # Max response size (1 MiB)
# (kebab-case spellings — interval-secs, timeout-ms, max-body-bytes — are
# accepted as aliases.)

# Example: monitor a local model-proxy service.
# [[metrics.targets]]
# name = "model-proxy"
# url = "http://127.0.0.1:9091/metrics"
# metrics = [
#   "http_requests_total",
#   "process_resident_memory_bytes",
#   "model_proxy_active_requests",
#]
# labels = { instance = "local" } # optional exact-match labels

# Bottom file-manager drawer (hidden by default; toggle with Ctrl+Alt+f). Runs a
# pinned, bundled yazi with its own config kept separate from the system.
[drawer]
# File manager to run. Empty = the bundled, pinned yazi.
command = ""
# yazi config dir (YAZI_CONFIG_HOME). Empty = a private ~/.superzej/yazi, seeded
# with superzej's bundled config and recolored to match [theme] accent. Use
# "system" to point at your own ~/.config/yazi instead, or give an explicit path.
config_home = ""
# Drawer geometry. height: "35%" or a row count. width: "full" | "center".
height = "35%"
width = "full"
# Image previews are off by default in the bundled/private yazi config. Text/code
# previews remain on. With config_home = "system", superzej does not rewrite your
# yazi config, so containment below is still the safety net.
image_previews = false
# Show git status as a linemode in the drawer (added/modified/deleted/etc.).
# Seeds the bundled git.yazi plugin into the private config and registers it as a
# fetcher; set false to remove it. Ignored with config_home = "system".
git_status = true
# Run yazi and preview helper children in a bounded user systemd scope when
# systemd-run is available. Empty limit strings omit that property.
contain = true
memory_max = "2G"
memory_swap_max = "512M"
cpu_quota = "200%"
# Hidden-drawer keepalive: pool_limit caps how many hidden yazi panes are kept
# warm (oldest evicted past the limit; 0 = hide kills the pane). prewarm spawns a
# hidden drawer per worktree so the first toggle is instant — off by default so
# invisible yazi instances never accumulate unbidden.
pool_limit = 1
prewarm = false

# GitHub PR data feeding the right panel.
[pr]
ttl_secs = 30          # cache TTL before a live `gh` re-fetch (SUPERZEJ_PR_TTL)

# Issue-tracker integration — surfaces assigned issues in the Work tab's `issues`
# section. Multiple trackers aggregate into one list, so you can run, say, Linear
# for product work and Jira for a client at the same time.
[issues]
# `providers` aggregates several trackers at once (recommended). When set it wins
# over the single `provider`. Valid: "linear", "github", "jira".
#   providers = ["linear", "jira"]
providers = []
# `provider` is the legacy single-tracker form, used only when `providers` is empty.
provider = "none"            # "none" disables the integration
ttl_secs = 60                # cache TTL before a background re-fetch
max_issues = 100             # cap on issues fetched/displayed (per provider)
filter_assignee_me = true    # pre-filter to issues assigned to you
move_on_merge = false        # when a worktree's PR merges, move its linked issue to Done

# [issues.linear]
# api_key = "env:LINEAR_API_KEY"  # `env:VAR` reads from the environment
# team_id = ""                    # restrict to one team ("" = all)
# workspace_slug = ""             # used for issue URLs (inferred if empty)

# [issues.github_issues]
# extra_flags = ["--assignee", "@me"]  # extra `gh issue list` flags

# [issues.jira]
# base_url = "https://myorg.atlassian.net"
# email = "me@myorg.com"
# api_token = "env:JIRA_API_TOKEN"
# project_key = ""                # restrict to one project ("" = all)

# The "My Work" (Mine) panel is scoped to the ACTIVE worktree's repo by default:
# GitHub issues/PRs are auto-filtered to the repo's `origin` remote, so no config
# is needed. To scope Linear/Jira per repo, put an `[issues]` overlay in that
# repo's root `.superzej.toml` — only the keys you set override the global config:
#   [issues.linear]
#   team_id = "TEAM-123"          # this repo's Linear team
#   [issues.jira]
#   project_key = "ACME"          # this repo's Jira project
# Press `a` in the Mine section to toggle between this-repo and all-repos views.

# Cross-provider CI/CD inspection — run history, jobs/steps, logs (AV group).
# GitHub Actions reuses the existing `gh`/GH_TOKEN auth (no sub-table needed).
[ci]
provider = "auto"          # auto | none | github | gitlab | drone | woodpecker | jenkins | argo
ttl_secs = 30              # cache TTL before a background re-fetch of run history
poll_interval_secs = 30    # background poll cadence while a run is in-flight
max_runs = 50              # how many recent runs to fetch/display
live_refresh = false       # start the CI view with live refresh on (toggle: ctrl+l)
log_tail_lines = 2000      # cap on fetched log lines (the tail is kept)

# Per-provider endpoints + tokens. Tokens accept "env:VAR" so secrets stay out
# of this file. Only the provider you use needs configuring.
[ci.gitlab]
host = ""                  # self-hosted base URL; "" = gitlab.com
token = "env:GITLAB_TOKEN"
[ci.drone]
server = "env:DRONE_SERVER"
token = "env:DRONE_TOKEN"
[ci.woodpecker]
server = "env:WOODPECKER_SERVER"
token = "env:WOODPECKER_TOKEN"
[ci.jenkins]
url = ""                   # per-instance Jenkins base URL
user = ""                  # basic-auth user
token = "env:JENKINS_TOKEN"
[ci.argo]
server = ""                # empty = ambient argo/argocd/kubeconfig context
token = "env:ARGOCD_TOKEN"

# Top-level app tab strip. Only "work" (your worktree IDE) is available today;
# unknown ids are ignored.
# Valid ids: "work".
[apps]
default_tab = "work" # initial tab (SUPERZEJ_APPS_DEFAULT_TAB); "work" = your worktree
tab_order = ["work"]

# The per-session daemon that pushes live diff/PR updates to the panel.
[watch]
pr_interval_secs = 20  # PR refresh cadence (SUPERZEJ_WATCH_PR_INTERVAL)

# Git write-operation knobs for the panel's lazygit-style features
# (line staging, interactive rebase, cherry-pick, bisect, undo, …).
[git]
override_gpg = false   # true => history rewrites pass -c commit.gpgSign=false
                       # -c tag.gpgSign=false, so a gpg passphrase prompt can
                       # never hang a background operation
merge_guard = true     # install a pre-merge-commit hook that refuses `git merge`
                       # in the canonical checkout from inside a sandbox (where
                       # its FS view can be incoherent and corrupt the merge);
                       # points at `szhost integrate`. No-op outside a sandbox or
                       # in linked worktrees. Escape hatch: SUPERZEJ_MERGE_GUARD_OFF=1

# User-defined git commands, surfaced in the git panel's custom-commands menu
# (`x`). `command` is a template expanded against the current selection — see
# the list below — then run via `sh -c`. The `| quote` filter shell-quotes a
# value. Referencing an empty selection is an error, never a silent "".
#   {{.SelectedCommit.Sha}} / .Short / .Subject / .Author
#   {{.SelectedBranch.Name}} / .Upstream      (also .SelectedLocalBranch.*)
#   {{.CheckedOutBranch.Name}} / .Upstream
#   {{.SelectedFile}}   {{.SelectedStash.Index}} / .Message
#   {{.WorktreePath}}   {{.Form.<Key>}}        (a prompt response)
#
# [[git_commands]]
# key = "P"                    # hotkey inside the custom-commands menu
# context = "branches"         # commits | branches | files | stash | global
# command = "git push --force-with-lease origin {{.SelectedBranch.Name | quote}}"
# description = "force-push selected branch"
# output = "popup"             # none | popup | terminal
# prompts = [{ type = "input", title = "Confirm branch", key = "Branch" }]

# Diagnostics. stderr is always on (level-gated, branded, colored on a TTY); the
# file sink is opt-in. SUPERZEJ_LOG is a tracing-style filter that refines the
# level per-module, e.g. SUPERZEJ_LOG=debug,superzej::db=trace
[log]
level = "info"            # error | warn | info | debug | trace
file = false              # mirror to a rotating file under `dir`
dir = ""                  # "" => $XDG_STATE_HOME/superzej/logs
rotation_size_mb = 5
max_files = 5
format = "text"           # text | json

# ── Keybindings ───────────────────────────────────────────────────────────────
# superzej owns its keybinds. Inspect with `superzej keys list`; check with
# `superzej keys validate`.
#
# By default, szhost has four modes: Normal, VimNormal, VimInsert, and Emacs.
# - Normal: The classic `Ctrl` and `Alt` chorded UI.
# - VimNormal: `h j k l` focus moves, `g g`/`G` scrolling, `i` to insert.
#   Also features a `Space` leader layer (e.g. `Space p` for panel).
# - VimInsert: Typing goes to pane. `Esc` back to VimNormal.
# - Emacs: `Ctrl x` / `Ctrl g` layer.
# Switch modes: `Ctrl Alt n` (Normal), `Ctrl Alt v` (VimNormal), `Ctrl Alt e` (Emacs).
#
# Rebind a built-in by its id (see `superzej keys list` for ids).
# Flat entries override chords globally.
# IDE keymap preset overlaid on the built-in defaults: "default" (none),
# "vscode", or "jetbrains". Maps familiar chords (Ctrl+P quick-open, Ctrl+Shift+P
# command palette, Ctrl+B sidebar, …) to existing actions; [keybinds] below still
# override it. On first launch a one-time picker offers these; setting this key
# explicitly skips the picker. The vim/emacs MODES are separate — see [profiles].
# keymap_preset = "vscode"

[keybinds]
# new-worktree = "Ctrl w"
# toggle-sidebar = "Alt s"
# switch-font = "Alt f"  # opens the realtime font picker (alacritty profile)
# Multi-key sequences (a leader chord) are supported: bind a space-separated
# sequence and a which-key popup lists the next keys after you press the prefix.
# Use "Space"/"leader" for the space key. Sequences are safest in the modal
# vim/emacs modes (in the default mode a bare-key prefix would be intercepted
# before reaching the focused pane), e.g.:
# [keybinds.vim_normal]
# new-worktree = "Space g w"   # press Space, then g, then w
# Sidebar navigation (global):
#   Alt ↑/↓        navigate worktrees, wrapping WITHIN the current workspace
#                  (in the TERMINALS region, cycles terminals within the host)
#   Shift+Alt ↑/↓  switch to the previous/next *workspace* (a real context
#                  switch); at the boundary it overflows into the TERMINALS
#                  region (and its host groups) and wraps back around
#   Alt+`          toggle between the workspaces and TERMINALS regions, restoring
#                  the last item you were on in each
#   Alt+1..9       jump straight to the worktree at that slot in visible order
#   Ctrl+1..9      jump straight to the workspace at that slot in visible order
#                  (the Alt/Ctrl digit hints are revealed on the rows while the
#                  sidebar is focused — Alt+s — and shown in the Ctrl+K menu)
#   Ctrl+Alt ↑/↓   *reorder* (move) the selected item: the workspace under the
#                  sidebar cursor if the sidebar is focused, else the active
#                  worktree within its workspace
# Workspaces and worktrees keep the order you set; cycle worktree sort modes
# with `s` while the sidebar is focused.
# prev-workspace = "Shift Alt Up"
# next-workspace = "Shift Alt Down"
# toggle-region = "Alt `"          # bounce between workspaces and terminals
# summon-workspace-1 = "Ctrl 1"    # …through summon-workspace-9 = "Ctrl 9"
# summon-worktree-1 = "Alt 1"      # …through summon-worktree-9 = "Alt 9"
# summon-pin-1 = "Ctrl Alt 1"      # …through summon-pin-9 = "Ctrl Alt 9"
# move-item-up = "Ctrl Alt Up"     # (legacy id move-worktree-up still works)
# move-item-down = "Ctrl Alt Down"

# You can also scope rebinds to a specific mode:
[keybinds.vim_normal]
# focus-down = "J"

[keybinds.emacs]
# quit = "Ctrl x q"

# Define your own actions — a chord bound to either a shell command (`run`) or
# a built-in composite operation (`action` + `params`). Exactly one of `run` /
# `action` is required. `menu = true` surfaces it in the Cmd+K palette.
# [[actions]]
# name = "deploy"
# key = "Alt D"
# run = "just deploy"
# menu = true
# hint = "deploy"        # short statusbar hint (defaults to `name`)
# floating = true        # run a `run` command in a floating pane (false = tiled)
# close_on_exit = true   # close the pane when the command exits

# Composite actions invoke a built-in operation in-process (a shell `run`
# cannot — superzej is a single session with no IPC). Supported `action`s:
#
#   new-worktree — create a worktree non-interactively (the Alt+w wizard,
#     headless). params: `name` (a tail, or omit/"random" for an adjective-noun
#     name), `sandbox` (auto | podman-rootless | podman-rootful | docker |
#     bwrap | host; default = your configured default backend), `agent`
#     (shell | an [[agents]]/[[tools]] name; default = shell), `base` (source
#     ref; default = configured/auto base).
#
#   new-pane — spawn a pane in the active tab. params: `run` (command via your
#     shell; omit for an interactive shell), `placement` (down | right; default
#     right), `cwd` (worktree | active; default active).
#
#   file-worktree — move the active worktree into a sidebar folder, creating the
#     folder if it doesn't exist yet. params: `folder` (required, the folder
#     name). Bind one per folder you sort into; firing again files into the same
#     folder (no duplicates). The interactive picker is `move-worktree-to-folder`
#     (bindable / in the palette) when you'd rather choose or name a folder.
#     Every folder named by a file-worktree action surfaces automatically as a
#     destination — in that picker, in the Cmd-K palette ("File into: <name>"),
#     and in the which-key popup — even before anything has been filed there.
#
# A scratch worktree on bwrap with a shell, no prompts:
# [[actions]]
# name = "scratch-shell"
# key = "Alt N"
# action = "new-worktree"
# params = { sandbox = "bwrap", agent = "shell" }
# menu = true
#
# A pane tailing the dev log, split to the right:
# [[actions]]
# name = "logs-pane"
# key = "Alt L"
# action = "new-pane"
# params = { run = "tail -f log/dev.log", placement = "right" }
#
# File the active worktree into a named folder (leader: Alt-m-f, then a letter):
# [[actions]]
# name = "File: Ready to merge"
# key = "Alt m f r"
# action = "file-worktree"
# params = { folder = "Ready to merge" }
# menu = true
# [[actions]]
# name = "File: PRing"
# key = "Alt m f p"
# action = "file-worktree"
# params = { folder = "PRing" }
# menu = true

# Keybind profiles: a named layer selected by `profile = "<name>"` (or the
# SUPERZEJ_PROFILE env var / --profile flag). Applied *under* [keybinds], so a
# global rebind still wins. `default_mode` sets the host mode on launch. The
# names `vim`/`emacs` also start in the matching mode without an explicit
# default_mode. For the full keybinding cheatsheet, focus the panel and press 9.
# profile = "vim"
# [profiles.vim]
# default_mode = "vim-normal"
# [profiles.vim.keybinds]
# focus-down = "j"

# ── Profiles: whole-process firewall (H) ────────────────────────────────────
# `szhost --profile work` (or SUPERZEJ_PROFILE=work) runs a NAMED profile — a
# whole-process work/personal firewall. A named profile reroots its own world
# under ~/.superzej/profiles/<name>/: separate state DB + logs, its own worktrees
# dir, and profile-scoped credentials (GIT_CONFIG_GLOBAL / GH_CONFIG_DIR /
# GNUPGHOME under the profile, forge tokens dropped so they can't cross profiles;
# GIT_SSH_COMMAND pinned with IdentitiesOnly=yes only when profiles/<name>/ssh/id
# exists). The DEFAULT profile keeps today's shared paths untouched — no
# migration. A named profile also loads an optional full-config overlay from the
# REAL config home (never rerooted) at <XDG_CONFIG_HOME>/superzej/profiles/<name>/
# config.toml, layered below env/`--set`. Switch/launch with Ctrl+Alt+g (spawns a
# new terminal window running szhost --profile=<name>); one advisory window per
# profile (a second is warned-about, not refused — profile DBs are WAL-safe).
#
# CAVEAT: the firewall is only as strong as the loosest sandbox setting —
# `[sandbox] file_access = "all"`, `network = "host"`, or SSH agent forwarding
# defeat credential isolation.

# Per-workspace overrides, keyed by repo slug (the workspace tab prefix). Applied
# above [keybinds] but below a repo-root `.superzej.{toml,yaml,json}` overlay,
# which may also carry its own [keybinds] table — the most specific layer wins.
# [workspace.my-repo.keybinds]
# new-worktree = "Ctrl w"

# Per-program host-action overlays, keyed by the focused pane's program name.
# These intercept *before* the active mode — useful for binding a host action
# while a TUI like lazygit is focused.
# [program_keybinds.lazygit]
# palette = "Ctrl Alt k"

# Per-program key-injection remaps: rewrite a chord into the program's own keys
# (the right-hand side is sent to the pane) when it is not claimed as a host
# action. Single keys only.
# [program_remap.lazygit]
# "Ctrl j" = "Enter"

# Coding agents offered in the new-worktree picker.
# Use "__shell__" for a plain login shell.
#
# THIS LIST IS THE SOURCE OF TRUTH for which agents a SANDBOX/sprite provisions
# (installs + carries config/login for): every entry you surface here is set up in
# the sandbox; an entry you remove is NOT (so the picker both surfaces custom agents
# and disables defaults you don't want). The agent KIND is the entry's `provider`,
# else its command's program basename — kinds dedup (e.g. a managed-pi "Agent" +
# a "Vanilla Pi" → one `pi`). `[sandbox.home] agents = [...]` overrides this with an
# explicit install list; only when NO `[[agents]]` are configured at all does
# superzej fall back to detecting the host's agents.
#
# `provider` (optional) tags an agent for client-side account switching
# (CODEX_HOME / CLAUDE_CONFIG_DIR) AND fixes its provisioning kind. When omitted,
# it's inferred from the command's program basename (e.g. "codex …" → codex).
[[agents]]
name = "claude"
command = "claude"
# Optional per-entry keys ([[agents]] and [[tools]] share the same shape):
# provider = "claude"   # account-switching / provisioning kind; inferred from the
#                       #   command's program basename when omitted
# hints = [{ key = "Ctrl o", label = "open" }]  # statusbar hint overrides shown
#                                               #   while this program is focused

[[agents]]
name = "aider"
command = "aider --model sonnet"

# The MANAGED pi coding agent, embedded over ACP (the upper control plane). pi runs
# its own tools natively; superzej is ADDITIVE — it observes activity (the statusbar
# chip), routes pi's model through the proxy, and exposes its house tools
# (budget / fleet / worktree status) to pi via MCP-over-ACP.
#
# superzej OWNS this pi under `~/.superzej/pi`: a pinned binary + a managed agent
# dir (PI_CODING_AGENT_DIR) seeded with the superzej-acp extension package. Run
# `szhost agent setup` once (superzej also self-heals it on launch when this entry
# is present). The command sets PI_CODING_AGENT_DIR and runs the pinned binary;
# `$HOME` resolves per-context, so the SAME entry works on the host AND inside a
# sprite (where the managed pi is provisioned to `<home>/.superzej/pi`). The
# superzej-acp extension registers the proxy-routed model from the SUPERZEJ_PROXY_*
# env when [llm_proxy].route_agent is on. (A "Vanilla Pi" entry that does NOT set
# PI_CODING_AGENT_DIR — e.g. `command = "npx -y @earendil-works/pi-coding-agent"` —
# stays unmanaged, using the default ~/.pi.)
[[agents]]
name = "Agent"
command = 'PI_CODING_AGENT_DIR="$HOME/.superzej/pi/agent" exec "$HOME/.superzej/pi/node_modules/.bin/pi"'
provider = "pi"

# ── Managed tools ([managed_tools.<name>]) ──────────────────────────────────
# Per-tool overrides for superzej's managed-tool resolver (the pinned external
# binaries it acquires: the pi agent, the `bs` debugger, MCP servers). The
# resolver picks a binary in a fixed order — this override → the tool's name on
# PATH → superzej's own pinned download under `~/.superzej`. Declare an override
# only to force a specific binary; omit the table to use PATH/managed. Inspect
# resolution with `szhost doctor`.
# [managed_tools.pi]
# path = "/usr/local/bin/pi"      # explicit binary (highest-priority tier)
# args = ["--flag"]               # optional extra launch arguments

# ── MCP servers ([mcp_servers.<name>]) ──────────────────────────────────────
# User-declared Model Context Protocol servers the agent consumes. `szhost agent
# setup` merges these into the managed pi's settings (the de-facto `mcpServers`
# key) alongside the built-in superzej-acp house tools. Inspect with `szhost mcp
# list` / `szhost mcp emit`; install a server's binary (grant-checked) with
# `szhost mcp install <name>`.
# [mcp_servers.git]
# command = ["npx", "-y", "@modelcontextprotocol/server-git"]  # launch argv
# args    = ["--repo", "."]                                     # extra args
# source  = { type = "npm", package = "@modelcontextprotocol/server-git", version = "0.5.0" }
#                                 # optional: acquire the binary (type = npm | cargo)
# Capability grants gate acquisition (Zed-style, least-privilege): an install is
# refused unless a matching grant covers it. Kinds: process:exec, download_file,
# npm:install, cargo:install. `scope` is a glob (`*` within a path segment, `**`
# across). Omit for none (acquisition then refused).
# [[mcp_servers.git.grants]]
# kind  = "npm:install"
# scope = "@modelcontextprotocol/*"

[[agents]]
name = "shell"
command = "__shell__"

# Per-worktree tools (also bound to Alt-g/y/e//).
[[tools]]
name = "lazygit"
command = "lazygit"
# Optional (same shape as [[agents]] above):
# provider = ""         # account-switching / provisioning kind override
# hints = [{ key = "q", label = "quit" }]  # statusbar hints while focused

[[tools]]
name = "yazi"
command = "yazi"

# "editor" is special: with the default below, superzej resolves your editor
# from $VISUAL/$EDITOR (falling back to vi). Graphical editors are detected by
# name (code, cursor, zed, subl, gvim, …) and launched detached. Set an explicit
# command here to override, e.g. command = "code ." or command = "hx .".
[[tools]]
name = "editor"
command = "${EDITOR:-vi} ."

[[tools]]
name = "diff"
command = "git diff"

# Coding-agent subscription accounts (client-side account switching, item 656).
# Keep N logins per provider (e.g. personal + work) and pick which one a newly
# launched agent uses. superzej points the agent's credential-home env var
# (CODEX_HOME for codex, CLAUDE_CONFIG_DIR for claude) at the chosen account on
# launch — your real ~/.codex / ~/.claude is never modified, and a switch only
# affects agents started *after* it (running ones keep their account).
#
# Switch with Ctrl+Alt+a (or the "Switch agent account" palette entry). The
# picker also has "Add <provider> account…", which runs the provider's login in
# the focused pane against a fresh superzej-managed dir.
#
# Omit `dir` to let superzej manage the dir under
# $XDG_STATE_HOME/superzej/accounts/<provider>/<name>/ (then log in via the
# picker); set `dir` to adopt an existing login dir.
#
# [[accounts]]
# name = "personal"
# provider = "codex"
#
# [[accounts]]
# name = "work"
# provider = "codex"
# dir = "~/.codex-work"   # adopt an existing CODEX_HOME
#
# Make a repo default to an account (resolution: worktree override → this
# workspace default → global active → the CLI's own default home):
# [workspace.my-work-repo]
# accounts = { codex = "work", claude = "work" }
# Bind extra directories into the sandbox for THIS workspace only (same format
# as [sandbox] mounts below). These extend the global mounts; the global list is
# the "all workspaces" scope, this is the "per workspace" scope:
# sandbox_mounts = ["~/datasets:ro", "/opt/toolchain"]
# Default env bundle for this workspace (see [bundle.*] below):
# env_bundle = "work"

# ── Environment bundles (AU) ────────────────────────────────────────────────
# Soft "work vs personal" identities WITHIN one running process — the middle
# ground between per-provider account switching (above) and heavyweight process
# profiles ([profiles.*] / --profile, below). A bundle composes env vars +
# credential/config-dir redirection + account selection (+ optional dotfiles),
# binds at any scope (global / workspace / worktree), and is injected into EVERY
# pane spawn (shells too, not just agents). Switch with Ctrl+Alt+u (or the
# "Switch env bundle" palette entry); it affects panes launched after the switch.
# Precedence: base ◁ extends-chain ◁ global ◁ workspace ◁ worktree ◁ .env.
#
# [bundle.work]
# extends      = ["base"]                       # optional composition (low→high)
# accounts     = { claude = "work" }            # → CLAUDE_CONFIG_DIR (see accounts)
# env          = { ANTHROPIC_BASE_URL = "https://proxy.work", FOO = "env:HOST_FOO" }
# config_dirs  = { GIT_CONFIG_GLOBAL = "~/.config/git/work" }  # Tier-1 redirection
# dotenv       = true                           # opt into the worktree .env (below)
# home         = "managed"                       # Tier-3 synthetic HOME (opt-in)
# [bundle.work.dotfiles]                          # Tier-2 materialized dotfiles
# source = "~/dotfiles/work"
# mode   = "symlink"                              # "symlink" | "template"
#
# Secret values never sit in this file in plaintext — reference them through a
# resolver scheme and superzej runs the command at launch (off-loop, never
# persisted; a failure degrades to skipping the key):
# [secrets.resolvers]
# pass = "pass show {ref}"        # value "pass:work/anthropic" → runs `pass show work/anthropic`
# op   = "op read {value}"        # {value} = the full "op://vault/item/field"
# sops = "sops --decrypt --extract '[\"{key}\"]' {file}"   # {ref} split on last ':' → {file}:{key}
#
# Opt-in `.env`: with `dotenv = true`, a worktree's `.env` loads at LOWEST
# precedence (never overrides a bundle value), only after you allow-list it (the
# switcher prompts), and credential-shaped keys (*_TOKEN/*_KEY/*_SECRET/
# *_PASSWORD) are always dropped — a repo `.env` can never inject a token.

# General tasks: surfaced in the Tests panel and, later, Problems/Timeline/Search
# Everywhere. `kind = "test"` makes a task eligible for test discovery/runs.
#
# Tasks come from three sources:
#   1. explicit [[tasks]] entries below;
#   2. static discovery from existing runners/manifests (Justfile, Makefile,
#      Taskfile.yml, package.json, Cargo.toml, go.mod, pyproject.toml,
#      docker-compose.yml/compose.yaml, flake.nix, Procfile);
#   3. semantic aliases such as dev/test/lint/build/up that resolve to the best
#      explicit or discovered task in the current workspace/worktree.
#
# Discovery parses files only; superzej does not execute arbitrary project code
# while switching worktrees. Commands run only after an explicit user action.
#
# [tasks.discovery]
# enabled = true
# providers = [
#   "just",
#   "make",
#   "taskfile",
#   "package-json",
#   "cargo",
#   "go",
#   "python",
#   "docker-compose",
#   "nix",
#   "procfile",
# ]
#
# [tasks.aliases]
# dev = ["just:dev", "npm:dev", "vite:dev", "cargo:run", "compose:up"]
# test = ["just:test", "cargo:test", "npm:test", "pytest", "go:test", "nix:check"]
# lint = ["just:lint", "cargo:clippy", "npm:lint", "ruff"]
# build = ["just:build", "cargo:build", "npm:build", "nix:build"]
# up = ["compose:up", "just:up"]
# logs = ["compose:logs", "just:logs"]
#
# If no test task is configured, superzej falls back to the discovered `test`
# alias/provider chain instead of requiring manual config.
# [[tasks]]
# name = "cargo test"
# kind = "test"
# command = "cargo"
# args = ["test", "--workspace"]
# cwd = "."
# scope = "worktree"
# matcher = "cargo-test"

# [[tasks]]
# name = "pytest"
# kind = "test"
# command = "pytest"
# matcher = "pytest"

# matcher selects how output is parsed. Built-in matchers:
#   text:   cargo-test, go-test, pytest, jest, vitest, swift, ctest, elixir, …
#   json:   nextest, dart, flutter, rspec
#   report: junit (maven/gradle/sbt/php/deno), trx/nunit (.NET, Pester) — set
#           report_glob to the file(s), e.g. report_glob = "target/**/*.xml"
#   tap:    bats, prove (perl), busted (lua), pgTAP, node --test, anything TAP
# [[tasks]]
# name = "bats"
# kind = "test"
# command = "bats --formatter tap ."
# matcher = "tap"

# Worktree templates: reusable presets applied when creating a worktree (run
# "New worktree from template…" from the command palette). A template can set
# the base branch, branch prefix, sandbox backend, and agent (pre-selected in
# the wizard), start a set of pins, and lay out the initial panes. The pane
# layout is either a saved named layout (see "Save layout as…") via `layout`,
# or the `commands` shorthand (an even row-split running each command; "" = a
# plain shell). Pins are matched by name against [[pins]].
# [[worktree_templates]]
# name = "rust-feature"
# base = "main"
# branch_prefix = "feat/"
# sandbox = "podman"
# agent = "claude"
# pins = ["logs"]
# layout = ""              # a saved named layout ("Save layout as…"); wins over `commands`
# commands = ["nvim", "cargo watch -x test"]

# Resource ceilings. superzej NEVER auto-runs tests; these only cap an *explicit*
# run/discovery so a heavy suite can't pin the machine. When `systemd-run` is
# available, runs go in a transient `--user --scope` with these caps; otherwise
# they fall back to `nice`. Empty quota/mem = uncapped; test_nice = 0 disables.
[limits]
# tool_mem_max = "6G"        # memory cap for floating tool panes
# tool_mem_swap_max = "1G"
# test_cpu_quota = "150%"    # 150% = 1.5 cores for a test run; "" = uncapped
# test_mem_max = "4G"        # memory cap for a test run; "" = uncapped
# test_nice = 10             # niceness for test runs (0 disables)
# test_max_parallel = 1      # max concurrent test/discovery jobs across worktrees
# test_timeout_secs = 1800   # kill a wedged test run after N seconds (0 disables)
# discover_timeout_secs = 45 # discovery should be instant; cap it so a held
#                            #   cargo build-lock surfaces an error, not a spinner
# isolated_target_dir = true # run superzej's cargo under <worktree>/target/superzej
#                            #   so discovery/tests never block on the user's build lock

# Per-worktree disk-usage visibility, cleanup, and shared build caches. Each
# worktree's `target/` is the dominant disk cost when developing across many
# worktrees; these surface it, reclaim it on merge, and dedup compilation.
[disk]
# show_sizes = true            # per-worktree size badges in the sidebar + statusbar total
# warn_threshold_gb = 100      # statusbar warns (amber, red at 2x) above this total; 0 = off
# scan_interval_secs = 45      # background size-scan cadence (runs off the event loop, cached)
# auto_clean_on_merge = true   # `cargo clean` a worktree's target/ when its PR merges
#                              #   (checkout kept; active worktree + running builds skipped)
# clean_on_pr_closed = false   # also clean when a PR is closed without merging
# sccache = false              # inject RUSTC_WRAPPER=sccache into panes (no-op if not on PATH);
#                              #   shares dependency compilation across worktrees
# sccache_dir = ""             # SCCACHE_DIR ("" = sccache default); ~ and repo-relative paths ok
# shared_target_dir = ""       # one CARGO_TARGET_DIR shared across a repo's worktrees.
#                              #   Biggest disk win, BUT cargo's per-target build lock
#                              #   SERIALIZES concurrent builds across worktrees — opt-in.
#                              #   "" = off; ~ expands to home; relative paths resolve to the repo root.

# Session snapshot/restore hardening. Two knobs on the resurrection path: how
# much per-pane scrollback is captured and repainted so a restored pane shows its
# recent history instead of a blank screen, and how long a persisted running/
# active agent dot may age before it is coerced to a settled state at restore —
# so a session killed mid-run never resurrects a phantom forever-running dot.
[session]
# scrollback_lines = 500       # max plain-text scrollback lines captured per pane on
#                              #   snapshot and repainted on restore; 0 = disable (blank restore)
# restore_grace_secs = 600     # a persisted active/running activity dot older than this at
#                              #   restore is downgraded to a settled state; live FSM untouched

# Aggregated notification bus. Events (PR state, agent done/failed, test
# failures, log errors, worktree created) surface as sidebar badges + the
# in-app inbox, and optionally as OS desktop notifications.
#   desktop             — deliver OS toasts (Linux: notify-send, macOS: osascript)
#   desktop_min_urgency — "low" | "normal" | "critical"; events below this
#                         urgency stay in the inbox but never pop a toast
[notifications]
desktop = true
desktop_min_urgency = "normal"
# How non-agent pane exits join the attention model (item 524):
#   "failures_and_tasks" — crashes/non-zero exits + clean non-shell task panes (default)
#   "failures"           — only non-zero exits
#   "all"                — every non-agent exit, including clean interactive shells
#   "off"                — never route pane exits
process_exit = "failures_and_tasks"
# Startup routing mode ("" = default). Named modes are defined below in
# [notifications.modes.<name>]; switch at runtime with Ctrl+Alt+m.
active_mode = ""

# Per-kind attention priority. Three tiers drive the badges coherently:
#   "alert"  — raises the red ⚑ flag (panel header + sidebar + statusbar) and,
#              mapped to "critical" urgency, a desktop toast
#   "notice" — counts toward the neutral "N unread" badge, never the red flag
#   "info"   — inbox history only; never counted toward any badge
# Defaults: failures (agent_failed, test_failed, log_error, process_failed) are
# "alert"; lifecycle events (worktree_created, process_exited) are "info";
# everything else (assigned, mentioned, status_changed, blocker_resolved,
# pr_linked, overdue, pr_state_changed, agent_done) is "notice". Override any
# kind below (keys are the snake_case kind names). Unknown keys/values are ignored.
# [notifications.priority]
# agent_done = "alert"        # promote: flag me when an agent finishes
# worktree_created = "notice" # demote less: show in the unread count
# pr_state_changed = "info"   # silence: inbox-only

# User routing rules (item 420). Evaluated top-to-bottom at delivery time; a rule
# fires when EVERY present selector matches (absent selectors are wildcards):
#   kind / kinds       — a single kind or a list (snake_case names)
#   worktree           — glob over the worktree path (`*` any run, `?` any char)
#   source             — prefix of the source ref ("linear:", "pr:", …)
#   message            — regex matched against the message text
#   min_priority       — only fire at/above "info"|"notice"|"alert"
#   modes / profile    — only under this active routing mode / profile
# Actions: set_priority ("info"|"notice"|"alert"), route (a subset of
# "inbox"/"desktop"/"toast"/"sound"), mute (drop ephemeral channels, keep inbox),
# drop (drop entirely), sound ("bell"|"off"|<command>), stop (halt evaluation).
# [[notifications.rules]]
# name = "mute scratch worktrees"
# worktree = "*/scratch"
# mute = true
# [[notifications.rules]]
# message = "flaky|known-issue"
# drop = true
# [[notifications.rules]]
# kind = "agent_done"
# set_priority = "alert"      # sound + break through DND when an agent finishes
# All selectors / actions on one rule (each is optional):
# [[notifications.rules]]
# name = "work-hours PR alerts"
# kinds = ["pr_state_changed", "agent_done"]  # multi-kind selector (or `kind = "…"`)
# worktree = "*/work-*"       # glob over the worktree path
# source = "pr:"              # source-ref prefix ("linear:", "pr:", …)
# message = "urgent"          # regex over the message text
# min_priority = "notice"     # only fire at/above this priority
# modes = ["focus"]           # only under these routing modes (see below)
# profile = "work"            # only under this active profile
# set_priority = "alert"      # action: raise/lower the priority
# route = ["inbox", "desktop"] # action: restrict delivery channels
# sound = "bell"              # action: "bell" | "off" | a command line
# stop = true                 # action: halt rule evaluation here

# Do-not-disturb / quiet hours (item 426). During DND, notifications below
# `allow_priority` stay in the inbox but pop no desktop toast, in-app toast, or
# sound. Toggle at runtime with Ctrl+Alt+d (the toggle overrides the schedule).
#   windows — "HH:MM-HH:MM" ranges (may wrap past midnight) with an optional
#             leading weekday token ("Sat", "mon-fri", "sat,sun").
# [notifications.dnd]
# enabled = false
# windows = ["22:00-08:00", "sat,sun 00:00-24:00"]
# allow_priority = "alert"

# Sound / bell (item 429). `mode`: "bell" (terminal BEL, default), "command" (run
# a command line off-thread), or "off". Only fires at/above `min_priority`.
# [notifications.sound]
# mode = "bell"
# min_priority = "alert"
# command = "paplay /usr/share/sounds/freedesktop/stereo/complete.oga"
# [notifications.sound.per_priority]   # optional per-priority command overrides
# alert = "paplay /usr/share/sounds/freedesktop/stereo/dialog-warning.oga"

# Routing modes (item 427): named presets you switch between at runtime with
# Ctrl+Alt+m. A rule's `modes` selector limits it to the listed modes;
# `active_mode` sets the startup mode ("" = default). Per-profile overrides live
# under `[profiles.<name>.notifications]` (same keys as `[notifications]`).
# active_mode = ""
# [notifications.modes.focus]
# label = "Heads down"
# [notifications.modes.away]
# label = "Away"

# Top pinned-program strip: a horizontal band above the center that renders
# `location = "strip"` pins side by side (toggle Ctrl+Alt+t; grow/shrink at
# runtime). `ratio` is the fraction of the center band it occupies.
[strip]
ratio = 0.2
visible = true

# The right accordion panel. Three top-level tabs (git/work/system) group
# sections by concern; `[` / `]` cycle tabs, Alt+1/2/3 jump directly.
# `sections` reorders sections across all tabs — any section left out is hidden;
# an empty/absent list shows every section in the built-in order:
#   Git tab:    changes · commits · branches · stash · files
#   Work tab:   mine · pr · issues · problems · jobs · tests · symbols
#   System tab: notifications · logs · sandbox · telemetry · keys
# "mine" is the unified cross-repo "My Work" feed (assigned issues across all
# trackers + review-requested/authored PRs + high-priority notifications).
# The old "prs" and "tasks" keys still work as aliases for "pr" and "jobs".
# Unknown keys are ignored; reloads apply live.
[panel]
# sections = ["changes", "pr", "files", "tests", "telemetry", "keys"]
# When Esc returns focus to the center terminal from any chrome zone (sidebar,
# panel, a bar, the drawer), snap the right panel back to its default width and
# close the bottom file drawer. Set false to leave sizes exactly as you left them.
# collapse_on_escape = true

# In-pane scrollback / copy-mode search (distinct from the palette below).
[search]
# Lines of terminal output kept per pane for searching; a larger value searches
# further back at the cost of a little heap per pane.
history_lines = 10000
# Max fuzzy-matched results returned per search (capped at the visible rows).
max_results = 1000

# Search Everywhere palette (Ctrl+Space). Mode prefixes:
#   (none) = All (actions + recent files)   > = Files   / = Content
#   ~      = Worktrees (frecency opener)    @ = Git refs/commits/stashes
#   #      = Symbols
# Tab cycles modes; Esc closes.
#
# Navigation (no config needed):
# - `~` lists workspaces + worktrees ranked by frecency (open count × recency
#   decay, 7-day half-life) — type a fragment, Enter lands in that worktree's
#   tab. Every palette pick feeds the ranking.
# - "Connect to root" (palette command) jumps from the focused pane's cwd —
#   however deeply nested — to the tab of the worktree that owns it; a cwd
#   outside any registered workspace offers to add it.
# - "Clone and open" (palette command) takes a git URL, clones it off the
#   event loop into `workspaces_dir`, registers the workspace, and opens its
#   first worktree tab. (Alt+W manual entry does the same.)
# - Layout import: tmuxinator projects (`~/.config/tmuxinator/*.yml`) and sesh
#   sessions (`~/.config/sesh/sesh.toml`) appear automatically as templates in
#   the new-worktree template picker (window commands → an even pane split);
#   `[[worktree_templates]]` entries win name collisions. Read-only.
[palette]
# content_max_results = 500    # max grep matches before streaming stops
# file_max_results    = 200    # max file-path fuzzy results
# symbol_max_results  = 100    # max symbol grep results
# content_search_hidden = false  # include dotfiles / .gitignored paths

# Language-server integration: symbol search, go-to-definition, hover, and
# diagnostics. Servers start lazily on first use and stay warm per worktree.
# Built-in defaults (used only when found on PATH): rust-analyzer,
# typescript-language-server, pyright-langserver, gopls. Falls back to the
# tree-sitter / regex providers when no server is available.
[lsp]
# enabled = true               # master switch
# hover   = true               # show hover / signature previews
#
# Per-language server overrides. `lang` is one of rust / typescript / tsx /
# javascript / python / go. `command = ""` disables that language.
# [[lsp.servers]]
# lang    = "rust"
# command = "rust-analyzer"
# args    = []

# Pinned programs: summoned from anywhere with Ctrl-Alt-1..9 (in registration
# order; Alt-1..9 jumps to worktrees, Ctrl-1..9 to workspaces) or the tabbar's
# pin chips. Pins run on the host (no sandbox) and are managed by
# a supervisor (eager start, restart policy, health, survive workspace switches).
#
#   location = "tab"    opens/focuses a dedicated `pin:<name>` tab (default)
#   location = "layout" adds a tiled pane to the focused tab's active layout
#   location = "strip"  renders the pin in the top strip
#   location = "float"  opens the pin as a floating scratch overlay
#   scope    = "global" (default) | "workspace"   (workspace = which workspace)
#   start    = "lazy" (default) | "eager"         (eager = launch at session start)
#   restart  = "never" (default) | "always" | "on-failure"
#   singleton = true (default)                    (false = allow multiple instances)
#
# Optional: `args` (explicit argv, skips the shell), `env` (per-program vars),
# `label` (strip/chip text), `ratio` (this pin's weight in the strip). For layout/
# strip pins, omitted cwd means the focused repo/worktree if resolvable; for tab/
# float pins, omitted cwd means $HOME.
#
# location = "corner" docks the pin as a small bordered overlay in a screen
# corner (toggle with Ctrl+Alt+o), sized by `corner_width`/`corner_height`
# ("30%" of the screen, or an absolute cell count) and anchored by `corner`
# ("bottom-right" (default) | "bottom-left" | "top-right" | "top-left"). A single
# corner pin is live at a time. Great for a video player; audio plays through your
# normal system audio, and YouTube works via mpv's yt-dlp integration (pass a URL).
#   - On a kitty-graphics terminal (Ghostty, kitty, WezTerm) use `mpv --vo=kitty`
#     for CRISP pixel video: superzej relays the corner's kitty images to the outer
#     terminal, offset to the corner rect (auto-detected).
#   - Elsewhere use `mpv --vo=tct` — colored Unicode half-blocks (text+truecolor),
#     blocky but works on any terminal.
# [[pins]]
# name = "aerc"
# command = "aerc"
# location = "float"
#
# [[pins]]
# name = "video"
# command = "mpv --vo=kitty --really-quiet"   # or "--vo=tct" on non-kitty terminals
# location = "corner"
# corner = "bottom-right"
# corner_width = "30%"
# corner_height = "30%"
#
# [[pins]]
# name = "logs"
# command = "journalctl -f"
# args = []                # explicit argv (non-empty ⇒ launched directly, no shell)
# location = "strip"
# scope = "global"         # "global" (all workspaces) | "workspace"
# workspace = ""           # owning workspace (only used when scope = "workspace")
# singleton = true         # false = allow multiple instances
# start = "eager"
# restart = "always"
# label = "syslog"
# ratio = 1.5
# cwd = "~"
# env = { RUST_LOG = "info" }

# ── Batteries-included toolchain ─────────────────────────────────────────────
# How a sandbox/remote gets its language toolchains when the repo declares
# nothing but language manifests (package.json, pyproject.toml, go.mod, …) —
# i.e. no flake devShell / devenv / shell.nix / .tool-versions. By default
# superzej SYNTHESIZES a Nix devShell covering the detected languages (written
# to $HOME/.superzej/synth/<hash> in the sandbox and warmed during
# provisioning), instead of crude best-effort apt installs. Repos that declare
# their own environment are untouched — this table only governs the fallback.
[toolchain]
# mode = "auto"   # "auto"|"nix" = synthesize a Nix devShell (default);
#                 # "mise" = install runtimes via mise instead;
#                 # "off"  = legacy best-effort native (apt) runtimes
# Per-language nixpkgs package lists. An empty list (the default) uses the
# built-in mapping shown below; a non-empty list REPLACES it for that language.
# (Rust has no entry — rustup ships in the sandbox base image.)
# python = ["python3", "uv"]
# node = ["nodejs_22"]
# deno = ["deno"]
# jvm = ["jdk21", "sbt", "scala-cli"]
# go = ["go"]
# ruby = ["ruby"]
# extra = []      # nixpkgs packages appended for every language mix

# ── Sandbox / containers ──────────────────────────────────────────────────────
# Run each worktree's interactive process (agent/shell/tools) inside a
# container/sandbox. The git worktree stays on the host and is bind-mounted in
# at its real path, so the sidebar/panel/PR (which read git host-side) keep
# working while the agent/shell only sees the worktree and its git metadata.
#
# Backend comparison (for NixOS / host-toolchain users):
#   bwrap           — bubblewrap: no daemon, no image, sub-millisecond spawn.
#                     Exposes the host filesystem selectively; your Nix-store
#                     shell and tools are available without any extra mounts.
#                     Best default for NixOS users who just want containment.
#   podman-rootless — OCI image (Debian, Ubuntu, custom). Reproducible env,
#                     persistent named container, but ~50-200 ms per spawn and
#                     the host shell path (/run/current-system/sw/bin/zsh)
#                     doesn't exist inside the image — superzej probes for
#                     zsh/bash/sh at runtime and uses the first one found.
#   host            — no sandbox; process runs directly in the worktree dir.
#
# Per-repo overrides go in `.superzej.{toml,yaml,yml,json}` at the repo root
# under a `[sandbox]` table — only the keys you set override these globals.
[sandbox]
enabled = true

# ── Hardening preset ─────────────────────────────────────────────────────────
# A named bundle of OS-isolation knobs applied to the worktree's container.
# Selectable per level: here (global), per workspace/repo via a `.superzej.toml`
# overlay, or the SUPERZEJ_SANDBOX_PROFILE env var.
#   open     — no hardening; pre-preset behavior (escape hatch / back-compat).
#   hardened — read-only root + no-new-privileges + a process (pids) cap, with
#              networking and Linux capabilities left intact so interactive dev
#              (fetch/clone/build, debuggers, ping) keeps working. The default.
#   sealed   — full lockdown: network=none, read-only root, drop ALL caps,
#              no-new-privileges, tighter pids cap. For untrusted workloads.
# Under a read-only-root profile (hardened/sealed, the default), everything
# OUTSIDE the worktree is read-only — including your $HOME — so a sandboxed
# agent can't `cd` out and modify/delete host files. Writable: the worktree, its
# git dir, build caches, /tmp, and a narrow set of $HOME carve-outs for shell
# state (~/tmp, ~/.local/state, ~/.local/share, plus the legacy history files
# ~/.zsh_history and ~/.bash_history). ~/.keychain is carved for interactive
# (hardened) panes but NOT the sealed agent — it stores scripts your host login
# shells later *source*, so a writable ~/.keychain from a sealed sandbox would
# be a persistence vector. Coding-agent config dirs (CLAUDE_CONFIG_DIR /
# CODEX_HOME, or the ~/.claude / ~/.codex default) are also carved writable — for
# EVERY non-sealed pane, so an agent CLI you run *manually* in a sandbox shell
# can persist its runtime state (session-env, todos, shell snapshots) instead of
# its startup hooks dying "read-only file system" (sealed agents are excluded:
# an untrusted network=none agent must not write the host's real credential dir).
# `profile = "open"` restores a fully-writable $HOME (zsh history/zoxide/
# keychain) as the escape hatch; add more writable paths under `mounts` below.
profile = "hardened"

# Hardening preset for the embedded agent's tool container. When it differs from
# `profile`, the agent runs in its OWN separate, more-locked-down container
# (named `superzej-<slug>-szagent`); when equal, it reuses the worktree
# container. Defaults to `sealed` so agent-run commands have no network egress.
agent_profile = "sealed"

# ── Backend selection ────────────────────────────────────────────────────────
# Which containment backend to use. "auto" walks backend_chain until one works.
#   auto | podman-rootless | podman-rootful | docker | bwrap | bubblewrap |
#   systemd | systemd-run | apple | container | wsl | none | host
# NixOS tip: set "bwrap" here to skip the podman probes and get instant panes.
backend = "auto"

# Pre-selected backend in the new-worktree picker ("auto" = use backend_chain).
default_backend = "auto"

# The named execution environment (`[env.<name>]`, documented below) every
# worktree uses by default unless it/its workspace/repo selects another. Empty
# = the implicit "default" env (this `[sandbox]` block + `[sandbox.remote]`).
default_env = ""

# Probe order for "auto". First backend that is installed and usable wins.
# "none"/"host" anywhere in the list = uncontained fallback from that point on.
# NixOS users: move "bwrap" first if podman isn't installed.
backend_chain = ["podman-rootless", "podman-rootful", "docker", "bwrap", "host"]

# ── OCI image (podman / docker only) ────────────────────────────────────────
# Empty  = superzej's built-in default (debian:stable).
# Named  = pulled on first use (e.g. "ghcr.io/org/devenv:latest").
# bwrap / systemd ignore this — they use the host filesystem directly.
image = ""

# Docker Compose file to bring up before the first pane in a workspace.
# The named container is expected to be running when panes are spawned.
# compose = "docker-compose.yml"

# ── Network ──────────────────────────────────────────────────────────────────
# nat  — egress only, no inbound ports. Required for API-backed agents.
# host — share the host network stack (no isolation; fastest for local services).
# none — no network (offline/air-gapped agents).
network = "nat"

# Host ports to publish from the container: ["host_port:container_port", ...].
# E.g. expose a dev server started by the agent on port 3000:
# ports = ["3000:3000", "8080:8080"]
ports = []

# Outbound hostname policy, enforced via a per-container DNS interceptor.
# Allow-only these hostnames (empty = allow all); the block list wins when a
# hostname matches both.
network_allow = []
network_block = []
# Log all outbound DNS queries and connection attempts to the audit table.
network_audit = false

# ── Filesystem ───────────────────────────────────────────────────────────────
# How much of the host filesystem the sandbox can see:
#   worktree            — only the worktree dir (most isolated).
#   worktree_plus_caches — worktree + auto-detected language build caches
#                          (~/.cargo, ~/.npm, ~/.cache/pip, etc.). Default.
#   all / host          — entire host filesystem (read-write, least isolated).
#   none                — no filesystem access beyond the container root.
#   custom              — only the explicit mounts list below.
# Note: regardless of file_access, the default `hardened` profile makes
# everything outside the worktree/caches READ-ONLY (see `profile` above). To get
# a fully writable host filesystem use `file_access = "all"`; for the strictest
# scoping use `"custom"`/`"none"`. Both file_access and profile are overridable
# per-repo via a `.superzej.toml` overlay.
file_access = "worktree_plus_caches"

# Mount common language build caches from the host when file_access is
# worktree_plus_caches. Disable to get a fully cold cache on every pane.
auto_caches = true

# Extra bind mounts beyond what file_access provides.
# Formats: "host_path"              → rw at same path inside container
#          "host_path:ro"           → read-only at same path
#          "host_path:dest"         → rw at dest inside container
#          "host_path:dest:ro"      → read-only at dest
#          "host_path:dest:cache"   → read-write cache (shown in sandbox summary)
# ~ is expanded to $HOME.
# This is also the extension point for extra writable carve-outs under the
# read-only $HOME: a read-write DIRECTORY under $HOME (e.g. "~/.gnupg") is kept
# and overmounts the read-only parent. An EXISTING FILE is carved the same way
# (e.g. "~/.histfile" for a custom history path) — bwrap overmounts the existing
# inode. Only a NON-existent path can't be carved (bwrap can't create the
# mount-point under the read-only $HOME). A read-only FILE (e.g.
# "~/.gitconfig:ro") is served read-only by the $HOME bind.
# This is the GLOBAL ("all workspaces") scope for default bind dirs. For a
# single workspace, add `sandbox_mounts` under `[workspace.<slug>]` (see above);
# those extend this list. A repo-root `.superzej.toml` `[sandbox] mounts` can
# also override per repo.
mounts = ["~/.gitconfig:ro"]

# ── GPU passthrough (OCI only) ───────────────────────────────────────────────
# Expose a GPU device to the container. Values depend on the runtime:
#   "all"             — all GPUs (--gpus all / --device nvidia.com/gpu=all)
#   "/dev/dri/card0"  — specific device path
# Leave commented to disable GPU passthrough.
# gpu = "all"

# ── Environment ──────────────────────────────────────────────────────────────
# Host env vars forwarded into the SANDBOX. Extend this list if your agent needs
# additional credentials or toolchain vars.
#
# NOTE: separately, EVERY pane (sandboxed or not) is spawned clear-then-allowlist
# — it does NOT inherit szhost's whole environment, so the launching shell's
# GH_TOKEN / ANTHROPIC_API_KEY / SSH_AUTH_SOCK etc. do not leak into panes. A
# curated infrastructure base (PATH/HOME/locale/terminal/display + the XDG/DBus
# vars a rootless runtime needs) is seeded, then the pane's bundle/profile
# identity is layered on. To re-admit a specific var into a plain (non-sandbox)
# shell, set it via a [bundle.*] `env` entry.
env_passthrough = [
  "SSH_AUTH_SOCK",      # SSH key forwarding (needed for git push inside OCI)
  "GH_TOKEN",           # GitHub CLI auth
  "GITHUB_TOKEN",       # GitHub Actions / API compat alias
  "ANTHROPIC_API_KEY",
  "TERM",
  "COLORTERM",
  "GIT_CONFIG_GLOBAL",  # profile git identity into the sandbox (H)
  "GH_CONFIG_DIR",      # profile gh config into the sandbox (H)
]

# ── Shell ─────────────────────────────────────────────────────────────────────
# Shell for plain "shell" panes inside the sandbox.
# ""   = auto: for OCI containers superzej probes zsh → bash → sh at runtime
#        so it works even when the image doesn't have the host shell installed
#        (e.g. a Debian image has bash but not /run/current-system/sw/bin/zsh).
#        For bwrap / host the host's $SHELL path is used directly.
# Set an explicit name ("bash") or absolute path ("/usr/bin/zsh") to pin one.
shell = ""

# ── Init script ───────────────────────────────────────────────────────────────
# POSIX sh snippet run INSIDE the sandbox before each agent/shell starts (runs
# in every pane, before the login shell `exec`s). Useful for first-run tool
# installation, env setup, or container git config.
# init_script = "mise install 2>/dev/null || true"
init_script = ""

# ── Prepare hooks (host-side, one-time per worktree) ──────────────────────────
# Commands run ON THE HOST (off-loop, via `sh -lc` in the worktree) once when a
# worktree is created, before its first pane spawns. Unlike `init_script` these
# run on the host — with the writable Nix store, the Nix daemon, and full
# network — so they suit heavyweight setup that a sandboxed pane can't do
# itself. The built-in `direnv` warm (`warm_direnv`, below) runs alongside them.
# prepare = ["mise install || true", "pnpm install --frozen-lockfile || true"]
prepare = []

# ── direnv ────────────────────────────────────────────────────────────────────
# Pre-warm a worktree's `direnv` cache on the HOST so the in-sandbox `direnv`
# hook actually works. A worktree pane is a login shell, so your rc's `direnv
# hook` fires inside the sandbox; with `use flake`, a cold nix-direnv cache makes
# direnv rebuild the devShell — which writes/locks `/nix/store` and fails on the
# sandbox's read-only store (no daemon). Warming on the host (writable store +
# daemon) means the in-pane direnv replays the cached env read-only instead.
#   "auto"         — warm + `direnv allow` the worktree (trusts the repo's own
#                    .envrc, the same boundary `inject_devshell` already crosses)
#   "allowed-only" — warm only worktrees you've already `direnv allow`-ed
#   "off"          — never warm (the in-pane direnv falls back as before)
warm_direnv = "auto"

# Wrap the inner command in `devenv shell --`. Auto-enabled if devenv.nix is
# present in the worktree root and the `devenv` binary is on PATH.
devenv = false

# ── Nix devShell tooling ──────────────────────────────────────────────────────
# Tier A (read-only, safe): inject the repo's Nix flake `devShell` toolchain
# (its PATH + safe exported vars) into worktree panes. superzej resolves the
# devShell on the HOST (writable store + daemon) via `nix print-dev-env`, caches
# it under $XDG_STATE_HOME/superzej/devenv/, and prepends it to the pane's PATH —
# so a sandboxed pane that can't reach the Nix daemon still gets the project's
# linters/formatters/tools out of the box. No-op for repos without a devShell.
inject_devshell = true
# Which flake devShell a sandbox/sprite enters. Empty = the flake default (same as
# host dev). Set to a leaner attr (e.g. "sandbox" → `.#devShells.sandbox`) so a
# remote sprite builds/seeds a much smaller closure — only what's needed to build
# the project, not the full lint/test/preview toolset. Exported as
# SUPERZEJ_DEVSHELL into the sandbox; the repo's `.envrc` must read it
# (`use flake ".#${SUPERZEJ_DEVSHELL:-default}"`). Missing tools are then a
# `nix shell nixpkgs#<tool>` away in-pane.
# devshell = "sandbox"
# Tier B: bind-mount the host Nix daemon socket into the sandbox so full
# `nix develop`/`build`/`fmt` run INSIDE it. `true` forces it on for every
# sandbox. `false` (default) does NOT fully disable it: as a backstop it is
# auto-enabled for a local flake-backed worktree, so an in-sandbox `nix-direnv`
# cache MISS re-evals via the daemon instead of dying on the read-only
# `/nix/store`. The socket is a local unix socket, so this is compatible with
# `network = none`. To suppress the auto-backstop, set `warm_direnv = off` or
# use a `sealed` profile. Ignored if the host has no Nix daemon.
nix_daemon = false

# ── Missing backend behaviour ─────────────────────────────────────────────────
# What to do when no backend in backend_chain is available:
#   warn   — open the pane on the host and show a banner (default).
#   prompt — ask before falling back to host.
#   fail   — refuse to open the pane.
on_missing = "warn"

# ── Failover when the SELECTED environment can't be brought up ─────────────────
# Distinct from on_missing (which governs only the local Auto backend chain).
# When a *named* [env.<name>] or an explicit non-local placement (provider/k8s/
# ssh) fails to come up — e.g. a managed provider rejects the token, or a pod
# won't schedule — should superzej quietly fall back to another backend / the
# host, or stop?
#   false — (default) HALT that worktree's pane and show a warning overlay. A
#           remote/managed env is often required for correctness or safety, so a
#           silent drop to the host is refused. You explicitly re-enable failover
#           (here or per-env) or fix the env.
#   true  — walk backend_chain down to the host on failure (historical behavior).
# Override per environment with `[env.<name>] failover = true|false`.
failover = false

# Drive the OCI runtime against a REMOTE daemon instead of SSH-wrapping the whole
# backend argv (an alternative reach to `[env.<name>] placement = "ssh"`, for when
# the container daemon — not just the shell — lives on another box). Empty = local.
#   podman — a connection URL ("ssh://user@host/run/user/1000/podman/podman.sock")
#            injected as `--url`, or a configured connection name as `--connection`.
#   docker — a host ("ssh://user@host") injected as `docker -H`.
# Applies to create/inspect/exec/teardown alike. (Local backend detection still
# probes the local host; set this only when you know the remote daemon is up.)
oci_host = ""

# ── Personal environment layer ────────────────────────────────────────────────
# [sandbox.home] makes a sandbox/remote feel like LOCAL by reproducing *your*
# setup in it — independent of any repo. The PROJECT toolchain is derived
# automatically from the repo (flake.nix/devenv.nix/.envrc, .tool-versions,
# language manifests); this table is the generic, declarative PERSONAL layer on
# top. Applied to every provider/remote sandbox on first open, then checkpointed
# so it's one-time. Empty (the default) = nothing extra.
# [sandbox.home]
# # CLI tools installed in every sandbox. Nix-first (`nix profile install
# # nixpkgs#<tool>`, consistent names) when Nix is present, else a best-effort
# # native package manager (apt/apk/dnf). Bespoke installs go in `setup` below.
# tools = ["fd", "fzf", "atuin", "ripgrep"]
# # Host dotfiles (basenames under your $HOME) uploaded into the sandbox home.
# dotfiles = [".zshrc", ".gitconfig", ".tmux.conf"]
# # OR clone a dotfiles repo + run its install.sh/bootstrap.sh/setup.sh.
# dotfiles_repo = ""
# # Bring-your-own setup — inline commands run (in order) in every sandbox, e.g.
# # install an agent CLI or internal tooling that isn't a package.
# setup = []
# # OR a setup script (host path uploaded + run, or an in-sandbox path).
# setup_script = ""
# # Coding agents to make work out-of-the-box INSIDE the sandbox: known CLIs are
# # installed and every listed agent's host config/credentials are uploaded so
# # it's logged-in there (claude code, codex, or a custom one like hermes). NOTE:
# # this carries credentials into the remote VM — list only agents you trust there.
# agents = ["claude", "codex"]
# # Host services exposed INSIDE the sandbox via a reverse tunnel (over the
# # resident bridge) so an in-sandbox process/agent reaching 127.0.0.1:<port> hits
# # the HOST's service — a host localhost DB/API, or a host-bound MCP server.
# # Specs: "5432" (same port), "8080:5432" (host loopback port), "8080:db.lan:5432".
# reverse_forwards = ["5432", "11434"]
# # Opt-in (default false): carry your atuin shell-history credentials + config into
# # every sandbox so its history joins your atuin sync (host <-> sprites, via atuin's
# # own auto_sync). Uploads the dereferenced ~/.config/atuin/config.toml + the
# # key/session under ~/.local/share/atuin; NOT the history DBs (the server syncs
# # those). No-op if atuin isn't installed / there's no host atuin config. Carries
# # credentials into the remote — enable only where you trust it.
# atuin = true
# # How hard to reproduce YOUR host shell here (a ladder, default "portable"):
# #   clean       — no personal dotfiles/tools; a plain rc-free shell. Bulletproof.
# #   portable    — install tools + portable dotfiles, but SKIP (with a warning) a
# #                 dotfile that hard-codes paths absent in the sandbox (e.g. a
# #                 home-manager ~/.zshrc full of /nix/store/… paths) rather than
# #                 shipping a broken shell. The safe default.
# #   tool-parity — portable, plus install tools your rc references but didn't list.
# #   host-parity — reproduce the host nix closure so your EXACT dotfiles work
# #                 unchanged (experimental). Heavy — meant for long-lived boxes,
# #                 set per-env (see [env.<name>] below). Transport, auto-selected:
# #                   • P2P (no infra): with connect="ssh" + no binary_cache_url,
# #                     the host store IS the cache — the closure (zsh + starship/
# #                     atuin/direnv/fzf + what your rc sources) is pushed straight
# #                     into the sandbox over the WSS ssh tunnel (nix copy --to
# #                     ssh-ng://), then `nix profile install`ed onto PATH. No hosted
# #                     cache, no signing key. (Re)create the sandbox with
# #                     connect="ssh" first.
# #                   • Hosted cache: set [env.<name>.provider] binary_cache_* and
# #                     the host pushes there; the sandbox substitutes from it.
# #                   • home-manager: else set nix_home_flake (below).
# strategy = "portable"
# # When true (default), under portable/tool-parity a dotfile that references absent
# # store paths is skipped+warned instead of uploaded broken. false = upload anyway.
# portable_dotfiles_only = true
# # host-parity fallback: your home-manager flake for an in-sandbox `home-manager
# # switch` when no binary cache is available (the cache-first closure copy reuses
# # [env.<name>.provider] binary_cache_*). Empty = disabled.
# nix_home_flake = ""

# The personal layer is per-env overridable: keep a safe global default, but ask
# for full parity on a long-lived box and a clean shell on an ephemeral sprite.
# [env.bigbox.sandbox.home]
# strategy = "host-parity"
# [env.sprite.sandbox.home]
# strategy = "clean"

# ── Resource limits (OCI only) ────────────────────────────────────────────────
# Cap CPU and memory for the container (Docker/Podman units).
#   cpu    — fractional cores: "0.5" = half a core, "2" = two cores.
#   memory — bytes with suffix: "512m", "2g".
# Both default to unlimited when unset.
[sandbox.limits]
# cpu    = "2"
# memory = "4g"

# ── Named volumes (OCI only) ──────────────────────────────────────────────────
# Persistent volumes that survive container recreations.
# Key = volume name (created by podman/docker if absent), value = mount point
# inside the container. Useful for package caches that shouldn't cold-start
# on every `just build`.
# [sandbox.volumes]
# cargo-registry = "/root/.cargo/registry"
# node-modules   = "/root/.npm"
# pip-cache      = "/root/.cache/pip"

# ── Remote worktrees ──────────────────────────────────────────────────────────
# Run worktrees on a remote machine over SSH. Leave host empty for local use.
# Control-plane operations (git reads, container lifecycle) always use ssh;
# the interactive pane uses mosh (resilient to network changes) by default.
[sandbox.remote]
# Remote host. Accepts "user@host", bare hostname (uses $USER), or an SSH
# alias from ~/.ssh/config. Empty = local only (default).
host = ""
port = 22
# mosh — UDP tunnel; survives IP changes and flaky connections. Requires the
#         mosh package on both the local machine and the remote host.
# ssh  — plain SSH pty; works everywhere but drops on network interruption.
transport = "mosh"
# remote     — worktrees live on the remote host under remote_dir (default).
# sshfs      — worktrees are sshfs-mounted locally; slower but local toolchain.
# local_exec — experimental: agent runs locally against the remote filesystem.
mode = "remote"
# Where worktrees are stored on the remote host.
remote_dir = "~/superzej-worktrees"
# Forward the local SSH agent (ssh -A) so git push uses your local keys.
# Disable if the remote host has its own deploy key.
forward_agent = true

# ── Per-sandbox VPN / tunnel ──────────────────────────────────────────────────
# Attach a worktree's sandbox to its OWN overlay network / tunnel, with its own
# identity, leaving the host's networking (including any host tailscaled)
# completely untouched. Off by default (provider = "none").
#
# How it works: superzej runs the tunnel daemon as a per-worktree *sidecar* (it
# never embeds a tunnel datapath in-process, and never touches your host VPN).
# In the default `sidecar` mode the worktree container joins the sidecar's
# network namespace, so its ONLY egress is the tunnel and its own capabilities
# stay untouched (NET_ADMIN / /dev/net/tun live in the sidecar, not the
# worktree). Bring-up runs off the event loop with a bounded readiness wait.
[sandbox.vpn]
# Provider: none | tailscale | headscale | wireguard | openvpn | netbird |
#           zerotier | custom. `headscale` is `tailscale` pointed at a
#           self-hosted control server (set tailscale.login_server below).
provider = "none"
# Attach mode:
#   sidecar      — companion container owns the netns; worktree joins via
#                  `--network container:<sidecar>` (default; best isolation).
#   proxy        — userspace tunnel exposes a SOCKS5/HTTP proxy; only proxy-aware
#                  traffic is tunneled (not a containment boundary). The only
#                  honest option for the bwrap/systemd backends.
#   in_container — run the VPN client inside the worktree container itself
#                  (needs NET_ADMIN + /dev/net/tun; weakens `hardened`).
#   netns        — join a host-prepared named netns (host-toolchain; best-effort).
mode = "sidecar"
# Override the provider's default sidecar image. Empty = provider default.
sidecar_image = ""
# Seconds to wait for the tunnel to come up before applying on_error.
ready_timeout_secs = 30
# When the tunnel can't come up:
#   fail    — refuse to launch (don't fall back to a less-isolated network).
#   warn    — launch with the tunnel down (loud warning).
#   offline — force network=none so nothing leaks onto the host network.
on_error = "fail"
# DNS composition:
#   tunnel       — the overlay owns resolution (MagicDNS / pushed DNS); the
#                  network_allow/network_block filter is bypassed (default).
#   filter-front — chain the allow/block DNS filter in front of the tunnel's
#                  resolver (preserves auditing). NOTE: with a sidecar tunnel the
#                  filter can't yet reach the sidecar's netns, so this currently
#                  behaves like `tunnel`; the resolver-chaining seam exists.
#   filter-only  — ignore the overlay's pushed DNS, keep the filter only.
dns = "tunnel"
# Request an ephemeral node identity where supported (Tailscale/Headscale/
# NetBird) so the device auto-deregisters from the control plane on teardown.
ephemeral = true
#
# Tip: pair `provider` with the `sealed-tunnel` (alias `tunnel-only`) hardening
# profile for a worktree that is fully cap-dropped AND has no host egress — its
# only route is the tunnel. Plain `sealed` refuses a VPN (network=none).
#
# Secrets: auth keys / configs accept a secrets-ref so they never sit in plain
# text here — "env:VAR_NAME" reads an env var, "file:~/path" reads a file. The
# resolved secret is injected into the *sidecar* only, never the worktree, so a
# coding agent in the worktree can't read it.

# [sandbox.vpn.tailscale]   # provider = "tailscale" or "headscale"
# auth_key = "env:TS_AUTHKEY"   # prefer an ephemeral, pre-authorized, tagged key
# login_server = ""             # set to your Headscale URL for provider="headscale"
# tags = ["tag:dev"]            # ACL tags advertised by this node
# exit_node = ""                # route egress through this exit node
# accept_routes = false         # accept subnet routes from the tailnet
# hostname = ""                 # node name (default: derived from container name)
# advertise_routes = []         # CIDRs to advertise as subnet routes
# extra_args = []               # extra `tailscale up` flags

# [sandbox.vpn.wireguard]   # provider = "wireguard"
# config_path = "/etc/wireguard/wg0.conf"   # a wg-quick .conf, OR:
# config = "file:~/wg/dev.conf"             # inline body via a secrets-ref

# [sandbox.vpn.openvpn]     # provider = "openvpn"
# config_path = "~/ovpn/dev.ovpn"
# auth_user_pass = "file:~/ovpn/creds"      # "user\npass"
# extra_args = []

# [sandbox.vpn.netbird]     # provider = "netbird"
# setup_key = "env:NB_SETUP_KEY"
# management_url = ""                        # self-hosted control plane
# hostname = ""

# [sandbox.vpn.zerotier]    # provider = "zerotier"
# network_id = ""                            # 16-hex network id
# controller_url = ""                        # self-hosted controller/moon
# api_token = "env:ZT_API_TOKEN"             # to auto-authorize the member

# [sandbox.vpn.custom]      # provider = "custom" — escape hatch for any tunnel
# up = "..."                                 # establishes the tunnel
# down = "..."                               # tears it down
# ready_check = "..."                        # exit-0 means ready (polled)
# image = ""                                 # sidecar image (mode=sidecar)
# {name}, {netns}, {worktree} expand in the commands above.
# [sandbox.vpn.custom.env]
# FOO = "bar"

# ── Ingress sharing (`[share]`) ─────────────────────────────────────────────
# The INBOUND sibling of [sandbox.vpn]. Where the VPN block gives a worktree
# *egress* through an overlay, [share] exposes a service running *inside* a
# worktree (a dev server, a PR preview, a webhook/OAuth callback) to the outside.
# Provider-pluggable; pick the one that matches your reach:
#   bore      — instant raw-TCP public URL, zero infra (the no-account default)
#   frp       — self-hosted public HTTPS + subdomains (+ TCP/UDP): demos/webhooks
#   tailscale — private to your tailnet (`serve`) or public (`funnel`); reuses
#               the worktree's [sandbox.vpn] tailscale tunnel — NO new auth
#   iroh      — peer-to-peer (dumbpipe): a teammate connects with a ticket; never
#               touches the public web, NAT-traversing
# Disabled by default. Open one with `superzej share start <port>` or Alt+Shift+S.
[share]
provider = "none"   # none | bore | frp | tailscale | iroh
# Requested reach: public | private. Authoritative only where the backend can do
# both (tailscale serve vs funnel); bore/frp are public-only (private downgrades
# with a warning), iroh is always peer-private.
visibility = "public"
# Safety guard: when false, refuse any share reachable from the PUBLIC INTERNET
# (frp http(s), tailscale funnel). Private/team/peer shares are unaffected. The
# statusbar badge renders AMBER while a worktree is publicly exposed.
allow_public = true
# Intent-first reach → provider mapping. When ≥2 of these are set, Alt+Shift+S
# offers a "Share to…" picker (🌐 public / 👥 team / 🔗 peer) instead of using the
# single `provider` above; pick *who* should reach it and the provider is chosen
# for you. Each defaults to "none" (no picker). Recommended:
# public = "frp"        # internet, browser-reachable
# team   = "tailscale"  # your tailnet / a teammate
# peer   = "iroh"       # hand a teammate a ticket
# When the share can't come up: fail (surface the error) | warn (note and skip).
on_error = "fail"
# Seconds to wait for the URL to appear before applying on_error.
ready_timeout_secs = 20

# [share.bore]   # provider = "bore" — https://github.com/ekzhang/bore
# to = ""                       # relay host running `bore server`; "" = bore.pub
# secret = "env:BORE_SECRET"    # shared HMAC (secrets-ref); must match the server
# remote_port = 0               # port to bind on the relay; 0 = relay chooses
# local_host = "127.0.0.1"      # interface the dev server listens on
# extra_args = []               # extra `bore local` flags

# [share.frp]    # provider = "frp" — https://github.com/fatedier/frp (self-host)
# server_addr = "frps.example.com"   # your frps host (required)
# server_port = 7000                 # frps control port
# token = "env:FRP_TOKEN"            # shared token (secrets-ref); matches frps
# proxy_type = "https"               # https | http | tcp | udp
# subdomain_host = "share.example.com"  # the server's subDomainHost (for the URL)
# subdomain = ""                     # "" = a stable per-worktree slug <name>-<port>
# remote_port = 0                    # tcp/udp only; 0 = server chooses
# vhost_https_port = 443             # server HTTPS vhost port (for the URL suffix)
# extra = []                         # extra frpc.toml lines (appended to [[proxies]])

# [share.tailscale]   # provider = "tailscale" — needs [sandbox.vpn] = tailscale
# funnel = false       # false = `tailscale serve` (tailnet-only); true = public
# https_port = 443     # serve/funnel HTTPS port (funnel: 443/8443/10000 only)

# [share.iroh]    # provider = "iroh" — https://github.com/n0-computer/dumbpipe
# extra_args = []  # extra `dumbpipe listen-tcp` flags (e.g. a self-hosted relay).
#                  # The consumer connects with `dumbpipe connect-tcp <ticket>`.

# ── Automatic port forwarding / browser preview (`[forward]`) ───────────────
# The outbound-localhost sibling of [share]: when a dev server binds a port INSIDE
# a worktree's sandbox (container / ssh host / k8s pod), superzej auto-detects it
# and forwards it to the host so it's previewable at http://localhost:<port>.
# Active forwards appear in the System panel; press `o` to open the focused one in
# your browser. On by default — forwards bind loopback only, so this is safe.
[forward]
auto = true            # auto-detect + forward newly-bound sandbox ports
range = "8000-8999"    # host-port range for remaps when a port's own number is taken
ignore = []            # container ports never to forward, e.g. [5432, 22]
only = []              # if non-empty, ONLY forward these container ports
bind = "127.0.0.1"     # host interface to bind forwards on (loopback = host-local)
poll_secs = 2          # how often the sandbox is scanned for new listening ports
browser = ""           # "open in browser" command; "" = $BROWSER, then xdg-open/open
open_on_detect = false # auto-open the browser when a new forward comes up
# Conflict handling: if a detected port's own number is already bound on the host,
# the forward is remapped to the next free port in `range` and a notification shows
# the real URL (e.g. "port 3000 in use → forwarded at localhost:8001").

# ── Named execution environments (`[env.<name>]`) ───────────────────────────
# A reusable *library* of execution environments. Each bundles three orthogonal
# axes: a PLACEMENT (where processes run — local / ssh / k8s / provider), an
# isolation OVERLAY on top of `[sandbox]` (`[env.<name>.sandbox]`), and a DATA
# mode (where the worktree files live). A workspace/repo/worktree then selects
# one by name. Selection precedence (most specific wins):
#   worktree `env_name` (DB) → workspace `env_name` (DB) → repo `.superzej.*`
#   `env = "…"` → global `default_env` (below) → the implicit `"default"`.
# The `"default"` env is this `[sandbox]` + `[sandbox.remote]` block — so with
# no `[env.*]` defined, nothing changes. Manage selections with `superzej env`.
#
# Pick the default env for every worktree that hasn't chosen one (empty ⇒
# "default"). Lives under `[sandbox]`; shown here for context.
# default_env = ""
#
# Example 1 — custom local containers (a pinned image, sealed hardening):
# [env.local-containers]
# placement = "local"
# [env.local-containers.sandbox]
# backend = "podman"
# image = "registry.example.com/dev:latest"
# profile = "sealed"
#
# Example 2 — a company Kubernetes cluster (exec into a pod via kubectl):
# [env.company-k8s]
# placement = "k8s"
# data = "in_env"            # files live in the pod
# [env.company-k8s.sandbox]
# backend = "none"           # the pod IS the isolation boundary
# [env.company-k8s.k8s]
# kubectl = ""               # kubectl binary (empty ⇒ `kubectl` on PATH)
# context = "company-prod"
# namespace = "dev-blake"
# pod = "sz-dev"             # target pod name (exec'd into)
# container = ""             # optional `-c <container>`
# pod_template = "~/.sz/dev-pod.yaml"   # `superzej env up` applies this (spawn custom env)
# image = "registry.example.com/dev:latest"  # OR template-less `kubectl run`
# remote_access = true       # `superzej env forward 8080:80` (kubectl port-forward)
# # `superzej env up` spawns the pod + waits Ready; `env down` deletes it.
#
# Example 3 — a hosted agent sandbox provider (e.g. Daytona). Two modes:
# (a) static/CLI — `exec_command` is an argv template, `{id}` → the sandbox id:
# [env.datonya]
# placement = "provider"
# [env.datonya.provider]
# provider = "daytona"
# id = "sb-1234"
# exec_command = ["daytona", "ssh", "{id}", "--"]
# up_command = ["daytona", "create", "--id", "{id}"]   # run by `superzej env up`
# down_command = ["daytona", "delete", "{id}"]         # run by `superzej env down`
# # (b) API — `superzej env provision` creates a sandbox over Daytona's REST API
# # (then set `id` to attach); `superzej env deprovision <id>` destroys it:
# # api_base = "https://app.daytona.io/api"
# # api_key_env = "DAYTONA_API_KEY"    # env var holding the Bearer token
# # template = "debian:stable"         # snapshot/image to create from
#
# Example 4 — a remote box over ssh/mosh with a dedicated ssh config + bastion:
# [env.gpu-box]
# placement = "ssh"
# data = "in_env"            # in_env (files on the remote) | sshfs | sync | local_exec
# failover = false           # per-env override of [sandbox] failover: true = this env
#                            #   may degrade to the local chain / host; false = halt+warn
# [env.gpu-box.ssh]
# host = "user@gpu-box"      # empty ⇒ inherit the worktree's own target / [sandbox.remote]
# port = 22
# transport = "mosh"         # mosh | ssh
# forward_agent = true
# ssh_config = "~/.ssh/work.config"   # ssh -F
# jump_host = "bastion.example.com"   # ssh -J
# identity = "~/.ssh/id_work"         # ssh -i
# extra_args = []
# # data = "sshfs" FUSE-mounts [sandbox.remote] remote_dir at
# # <superzej-dir>/mounts/<host-slug>; data = "sync" keeps a local working copy
# # there, kept coherent with the remote via an rsync delta. BOTH now mount/sync
# # AUTOMATICALLY on pane spawn and unmount/push on close (no manual `env up`),
# # and run the pane LOCALLY at the mountpoint. `superzej env up/down` still works
# # for an explicit one-off. Intended with `backend = "none"`/host.
#
# ── [host.<name>] — machines as first-class resources ────────────────────────
# A host is a machine that can run OCI containers, provisioned ONCE (connect →
# probe podman/docker → optionally install it with consent → deliver the baked
# multi-arch base image by digest → seed warm /nix + cargo volumes → Ready) and
# then shared by EVERY env/worktree that lands on it — the 20-minute-class
# setup cost is paid per host, not per sandbox. `[env.<name>] host = "<name>"`
# binds an env to a host; several envs may share one. Hosts are GLOBAL config
# only (a repo .superzej.toml can select a host-backed env, never define a
# host). Inspect + drive with `superzej host list|status|provision|probe`.
#
# [host.gpu-box]
# reach = "ssh"                # ssh | iroh | cloud | local
# image = ""                   # base-image override (name[:tag][@sha256:…]);
#                              #   empty = the built-in superzej-sandbox base
# install_runtime = "ask"      # never | ask | auto — consent for installing
#                              #   podman on the machine; NEVER silent. `ask`
#                              #   raises a confirm modal (or `host provision --yes`);
#                              #   the answer persists per host.
# delivery = []                # preference order: "ssh-stream" (registry-less
#                              #   resumable transfer, the default), "rsync",
#                              #   "registry", "skopeo", "build"; empty = auto
# volumes = ["nix-store", "cargo"]   # warm volumes seeded once and mounted into
#                              #   every sandbox; omit for both, [] for none
# probe_ttl_secs = 900         # Ready hosts re-verify (one cheap exec) after this
# [host.gpu-box.ssh]           # same knobs as [env.<name>.ssh]
# host = "user@gpu-box"
# port = 22
# transport = "ssh"            # the host control plane always uses plain ssh
# forward_agent = true
# ssh_config = "~/.ssh/work.config"   # ssh -F
# jump_host = ""               # ssh -J bastion
# identity = "~/.ssh/id_work"  # ssh -i
# extra_args = []
#
# # A NAT'd machine over an iroh (dumbpipe) tunnel: run
# #   dumbpipe listen-tcp --host 127.0.0.1:22
# # on it once and paste the ticket (env:/file: secret refs supported).
# [host.nat-laptop]
# reach = "iroh"
# [host.nat-laptop.iroh]
# ticket = "env:SZ_LAPTOP_TICKET"
# ssh_port = 22
# user = "me"
#
# # Bind envs to hosts: both of these pay gpu-box's setup once, share its
# # digest-pinned image + warm volumes, and spawn sandboxes near-instantly.
# [env.gpu]
# placement = "ssh"
# host = "gpu-box"
# [env.gpu-heavy]
# placement = "ssh"
# host = "gpu-box"
#
# # A provider-managed host (the cloud lowering: "provisioning" registers the
# # base image as the provider's bootable template/snapshot):
# [host.sprites-us]
# reach = "cloud"
# [host.sprites-us.cloud]
# provider = "sprites"         # sprites | daytona
# api_base = ""                # empty = the provider's default endpoint
# api_key_env = "SPRITES_TOKEN"   # env var holding the API token
# template = "superzej-base"   # template/snapshot the base image registers under
#
# Example 5 — a managed sandbox provider: Sprites (sprites.dev, Firecracker
# microVMs with a persistent fs + ~300ms checkpoints). One-time setup:
#   1. Generate a token at sprites.dev/account; export it (the REST API and the
#      `sprite` CLI both read it):  export SPRITES_TOKEN="my-org/token-id/secret"
#   2. Install + auth the CLI (used for the pane exec bridge):
#        curl -fsSL https://sprites.dev/install.sh | sh
#        sprite auth setup --token "$SPRITES_TOKEN"
#   3. Create the sprite once:  superzej env provider create --env sprites
#      (or `sprite create my-worktree`), then set `id` below to its name.
# [env.sprites]
# placement = "provider"
# data = "in_env"            # in_env: work in the sprite's persistent fs (default)
#                            # sync:   push the local worktree into the sprite on
#                            #         pane spawn, pull changes back on close.
# #                          # FULL LOCAL PARITY (in_env): a fresh sprite clones
# #                          # origin AND replays your local state on top —
# #                          # unpushed commits (a thin git bundle), uncommitted
# #                          # tracked changes (git diff HEAD), and untracked
# #                          # non-ignored files — so the sprite matches your
# #                          # working tree, not just origin. Automatic + best-
# #                          # effort (a capture/replay failure leaves the pristine
# #                          # origin checkout). Runs once on first provision (and
# #                          # on a warm-pool claim); re-opens reuse the fs.
# [env.sprites.provider]
# provider = "sprites"       # selects the SpritesProvider REST adapter
# id = "{repo}-{worktree}-{hash}"   # sprite name; tokens give a PER-WORKTREE sprite.
#                            #   {repo}=repo dir name, {worktree}=worktree dir basename
#                            #   (the branch slug), {hash}=stable digest of the full
#                            #   worktree path (the collision-defuser: two same-named
#                            #   branches in different repos still differ), {slug}=full
#                            #   path. Empty ⇒ this default (conflict-free across repos,
#                            #   org-wide). A literal with no token = one SHARED sprite.
#                            #   Clamped to a DNS-safe length, keeping the hash suffix.
# api_key_env = "SPRITES_TOKEN"        # empty ⇒ defaults to SPRITES_TOKEN
# # api_base = "https://api.sprites.dev/v1"   # empty ⇒ this default
# # workdir = "/workspace"   # data = "sync" pushes/pulls the worktree here
# # auto_provision = false   # create the sprite on first open if missing (8-E
# #                          #   warm-on-open) — over the REST API, so creation is
# #                          #   CLI-free (no `up_command`). Off by default —
# #                          #   creating a paid sandbox is opt-in. (The
# #                          #   `backend=sprites` launcher scaffolds it `true`.)
# # auto_checkpoint = false  # checkpoint the sprite on worktree close (suspend-on-
# #                          #   close, fast resume) — over the API, CLI-free. Off
# #                          #   by default (storage cost). Launcher scaffolds `true`.
# # --- provisioning speedups (make the one-time nix install + devShell faster) ---
# # nix_installer = "official"      # "official" (nixos.org --no-daemon, default +
# #                                 #   fallback) or "determinate" (faster Rust
# #                                 #   installer; falls back to official on failure)
# # nix_parallel_downloads = 0      # >0 sets http-connections + max-substitution-jobs
# #                                 #   (clamped 1..=256, e.g. 100) so the devShell's
# #                                 #   deps download in parallel — the biggest win
# # binary_cache_url = ""           # extra Nix substituter so the devShell is a
# # binary_cache_key = ""           #   download not a build (needs the public key)
# # binary_cache_push = false       # push the built devShell closure to the cache
# #                                 #   during provisioning (needs a signing key).
# #                                 #   ALSO used by [sandbox.home] strategy =
# #                                 #   "host-parity": the host pushes your dotfiles'
# #                                 #   /nix/store closure here so the sandbox
# #                                 #   substitutes it (pure-nixpkgs paths need no
# #                                 #   push — they come from cache.nixos.org). The
# #                                 #   sandbox must have EGRESS to the cache host
# #                                 #   (allow it in [sandbox] network_allow if the
# #                                 #   env filters egress).
# # host_cache = false              # Serve your HOST /nix/store as a LIVE binary cache
# #                                 #   (substituter) reachable from the sprite over the
# #                                 #   reverse tunnel, so in-sprite `nix develop`/`direnv`
# #                                 #   SUBSTITUTE prebuilt store paths from your host
# #                                 #   instead of building from source. A general cache
# #                                 #   over the WHOLE host store — strictly more capable
# #                                 #   than push_devshell's one-shot devShell upload,
# #                                 #   which it SUPERSEDES when set. Unsigned + loopback-
# #                                 #   tunnel-only (require-sigs=false in the sprite). The
# #                                 #   host serves it from the szhost process; needs a
# #                                 #   resident-bridge provider (sprites). Recommended.
# # push_devshell = false           # Use your HOST as the devShell cache (nix users).
# #                                 #   Seeds the repo's closure — ALREADY BUILT on your
# #                                 #   host (you run `nix develop`/direnv locally) —
# #                                 #   into the sandbox store. SCOPED: uploads only the
# #                                 #   paths public caches lack (the repo's from-source
# #                                 #   builds + rust-overlay output) via a file:// cache
# #                                 #   + the fs API; the sandbox fills the rest from
# #                                 #   cache.nixos.org → a local store hit, not a
# #                                 #   minutes-long from-source compile. No hosted
# #                                 #   cache/signing key needed; the host IS the cache.
# #                                 #   No-op without a nix devShell. Best-effort.
# #                                 #   (host_cache above supersedes this when both set.)
# # skip_devshell_warm = false      # skip the blocking devShell BUILD during
# #                                 #   provisioning. The repo's devShell then builds
# #                                 #   lazily in-pane on first `direnv`/`nix develop`
# #                                 #   instead of gating the loading screen on a
# #                                 #   multi-minute toolchain build → the shell comes
# #                                 #   up immediately. Trades a prebuilt (checkpointed)
# #                                 #   devShell for instant launch. No-op without nix.
# # connect = "exec"         # how the pane CONNECTS: "exec" (native WSS PTY relay,
# #                          #   default) or "ssh" (run sshd in the sandbox and attach
# #                          #   a local `ssh` client over the provider's TCP-over-WS
# #                          #   proxy — unlocks scp/sshfs/agent forwarding)
# # exec = "auto"            # how the interactive pane attaches:
# #                          #   auto — native API exec (PTY-over-WebSocket, NO
# #                          #          `sprite` CLI) when the provider supports it
# #                          #          (Sprites does), else the CLI. The default.
# #                          #   api  — force native API exec (error if unsupported).
# #                          #   cli  — always use the `*_command` CLI bridge below.
# #                          # Native exec also persists its session id, so a restart
# #                          # reattaches the live sprite session and replays scrollback.
# # The CLI bridge (used for exec = "cli", and as the auto fallback). PTY-capable:
# exec_command = ["sprite", "exec", "-s", "{id}", "--"]
# interactive_command = ["sprite", "exec", "-s", "{id}", "--tty", "--"]
# up_command = ["sprite", "create", "{id}", "--skip-console"]
# down_command = ["sprite", "destroy", "-s", "{id}", "--force"]
# # Wired axes (capability-gated, generic across providers):
# #  • EGRESS — [sandbox] network_allow/network_block are lowered to the sprite's
# #    DNS policy (POST /policy/network {rules:[{domain,action}]}) automatically
# #    on `superzej env provider create`.
# #  • SNAPSHOT — `superzej env snapshot [--label]` / `env snapshots` / `env restore <id>`
# #    (Sprites checkpoints).
# #  • FILE-SYNC — `data = "sync"` pushes the worktree into `workdir` on spawn and
# #    pulls it back on close (via the sprite /fs API; `.git` is skipped).
# #  • DATA PLANE — a provider worktree's git/diff/branches/files resolve INTO the
# #    sandbox (the chrome shows real state); a fresh sprite is repo-provisioned on
# #    open (clone for data=in_env, upload for data=sync).
# #  • RESIDENT BRIDGE — when a static-musl `szhost` is available (build:
# #    `nix build .#szhost-musl` or `just build-musl`; point SUPERZEJ_BRIDGE_BINARY
# #    at it), it's pushed into the sprite and run as `szhost bridge`, so git is
# #    fast (no per-op latency), file edits stream back live (fs.watch), activity
# #    dots reflect in-env CPU, and tests/jobs run in the sandbox.
# #  • NATIVE EXEC — with `exec = "auto"` (default) the interactive pane attaches
# #    over the Sprites WSS exec API directly (no `sprite` CLI), and reattaches its
# #    live session (replaying scrollback) across restarts. Set `exec = "cli"` to
# #    fall back to the `interactive_command` bridge.
# # FAILOVER — by default, if the sprite can't be brought up (bad/expired token,
# #   API down, quota), the worktree's pane HALTS with a warning overlay rather
# #   than silently dropping to a host shell (see [sandbox] failover). To let THIS
# #   env fall back to the local backend chain / host instead, override per-env:
# # failover = true            # this env may degrade to host; omit/false ⇒ halt+warn
# ── Sandbox lifecycle: warm/suspend + budget ───────────────────────────────
# Budget-governed warm policy for managed-provider sandboxes (sprites/ssh/k8s).
# A provider sandbox only stays *running* while a live exec session into it exists
# (a pane or the resident bridge); idle ones suspend for free (filesystem kept).
# Defaults are budget-safe — superzej's own sidebar/activity polling never wakes a
# suspended sandbox, idle ones suspend after the TTL, and the few most-recently-
# used (plus any busy or pane-held) stay warm for instant resume. All optional.
[lifecycle]
# enabled = true              # master switch; off ⇒ inert (today's behavior)
# max_warm = 2                # max sandboxes kept warm at once (bounds the
#                             #   most-recently-used keeps; active/busy/pane-held
#                             #   worktrees are always kept regardless)
# idle_ttl_secs = 300         # idle seconds before a non-essential warm sandbox
#                             #   may suspend
# eager = "active"            # provision AHEAD of focus so the one-time nix/devShell
#                             #   minutes happen in the background. off | active
#                             #   (active worktree + newly-created) | workspace
#                             #   (whole active workspace) | all (every worktree)
# keep_active_warm = true     # the focused worktree's sandbox is always warm
# keep_busy_warm = true       # a worktree with a live in-sandbox process stays
#                             #   warm past the TTL (dev server / agent)
# serve_cached_glyphs = true  # show cached git status/activity for non-warm
#                             #   provider worktrees instead of waking them to poll
# cost_per_warm_hour = 0.0    # est. $/warm-sandbox-hour, for the ceiling below
# cost_ceiling_per_hour = 0.0 # trim the warm set to stay under this $/hr; 0 ⇒ off
# [lifecycle.pool]            # WARM SPARE POOL: keep N pre-provisioned, unclaimed
# size = 0                    #   sandboxes ready per (repo, env) so the NEXT worktree
#                             #   CLAIMS one instantly (bind + branch checkout) instead
#                             #   of provisioning from scratch. 0 ⇒ disabled (default).
#                             #   Spares are checkpointed (suspend for free) + refill in
#                             #   the background after a claim. Adjust live with the
#                             #   warm-pool-increment / -decrement hotkeys (Ctrl+Alt+= /
#                             #   Ctrl+Alt+-); the sidebar header shows `warm ready/target`.
# max_idle_secs = 600         # reap an unclaimed pool member older than this (recycled)
# # Recycle checkpointed spares by restoring them IN PLACE (seconds) instead of
# # destroy+rebuild (minutes) when they go stale or their worktree is deleted;
# # lockfile-freshness guarded, destroy on any failure. false = always destroy.
# recycle = true
# ── LLM proxy (group U/V) ──────────────────────────────────────────────────
# The AI-traffic chokepoint daemon (binary `szproxy`). The shell never hard-
# depends on this — AI is strictly additive — so it is OFF by default. When
# enabled, the host launches szproxy and agents point OPENAI_BASE_URL /
# ANTHROPIC_BASE_URL at `listen`.
[llm_proxy]
enabled = false
# Address the daemon binds (and agents target).
listen = "127.0.0.1:8383"
# Backend selection: "sequential" (ordered failover, the M1 behavior),
# "load_balanced", or "speculative" (cascade — reserved for the AR work).
routing = "sequential"
# On a budget-cap breach: refuse the request (true) or downgrade to a cheaper
# tier (false). The kill-switch always refuses regardless of this setting.
refuse_on_breach = true
# Path to the proxy's routes document (JSON: { "routes": [ { "name", "backends":
# [ { "name", "base_url", "model", "api_key_env", "anthropic", "rpm", "burst",
# "context_limit", "defaults" } ] } ] }). Passed to szproxy as SZPROXY_CONFIG.
config_path = ""
# Streaming tunables (seconds). first_byte_timeout: wait for a backend's first
# usable token before falling through; idle_timeout: kill a stream gone silent
# this long; heartbeat: keep-alive cadence during upstream silence.
first_byte_timeout_secs = 45
idle_timeout_secs = 120
heartbeat_secs = 10
# In-flight token reduction: compress noisy tool/command output before it's sent
# upstream (strip ANSI, fold progress redraws, collapse blank/repeated lines, and
# at higher levels minify JSON / truncate huge blocks). Off by default — only
# `tool`-role content is touched, never the system prompt, so prompt caching
# holds. Levels: off | conservative | balanced | aggressive.
token_reduction = false
token_reduction_level = "conservative"
# Route a launched agent's model traffic through the proxy at `listen` by
# injecting provider config into the agent's environment at spawn. `route_agent`
# and `enabled` are ORTHOGONAL: `enabled` launches superzej's OWN szproxy;
# `route_agent` only injects the env — the pi extension's SUPERZEJ_PROXY_* vars
# (NOT ANTHROPIC_BASE_URL; see `route_claude`) → `listen`, and for a
# remote/provider sandbox an empty/"auto" `remote_base_url` stands up the reverse
# tunnel to it. So point agents at an EXTERNAL proxy already on `listen` (e.g. a
# separate model-proxy) with `route_agent = true` + `enabled = false` (superzej
# won't try to bind the same port); run superzej's own proxy with `enabled = true`
# (+ a `config_path` routes file, else it 404s — superzej warns at startup).
# `agent_api` is the pi-side API id for that endpoint — the proxy serves
# the Anthropic Messages API (/v1/messages), and pi's OpenAI client speaks the
# Responses API (which the proxy doesn't implement), so keep "anthropic-messages".
# `agent_model` is the model id the agent requests (the proxy maps it to a real
# backend, e.g. "model-proxy/standard" / "model-proxy/fast").
route_agent = false
# Additionally route Claude Code / the Anthropic SDK (anything honoring
# ANTHROPIC_BASE_URL) through the proxy. OFF by default: claude talks to Anthropic
# directly, so a down/racing proxy tunnel can't break it (a forced
# ANTHROPIC_BASE_URL pointing at a dead loopback port yields ConnectionRefused with
# no upstream fallback). pi routes regardless via SUPERZEJ_PROXY_*; flip this on
# only if you also want claude's traffic on the proxy. Requires `route_agent`.
route_claude = false
agent_api = "anthropic-messages"
agent_model = "model-proxy/standard"
# "The bouncer" (opt-in). When true, a launched agent runs inside its sealed
# `[sandbox] agent_profile` container and its built-in bash/read/edit/write tools
# are routed back through superzej over a bind-mounted unix-socket ACP channel.
# The consequential ones — shell, edit, write — are gated behind an interactive
# allow/deny overlay (read is auto-served). If `agent_profile` forces no network
# (the default `sealed`), the agent's only egress is the proxy, relayed over a
# unix socket (full exfil seal); a network-permitting profile (e.g. `hardened`)
# reaches the proxy via the container gateway instead. Off = the additive model:
# pi runs its own tools in-process and edits auto-apply.
bouncer = false
# Base URL an agent running INSIDE a remote/provider sandbox (a sprite VM that
# can't reach host loopback) uses to reach szproxy — a tunnel/public endpoint.
# With `route_agent`, superzej injects the SUPERZEJ_PROXY_* vars (and, when
# `route_claude` is also on, ANTHROPIC_BASE_URL + the per-worktree virtual key)
# into the sprite's shell so pi (and, with route_claude, claude code / the SDK)
# routes through the proxy. (Local/OCI agents already reach the proxy via
# loopback/gateway/unix.) EMPTY (the default) under `route_agent` ⇒ "auto": superzej
# stands up a reverse tunnel (the in-sandbox resident bridge ⇄ host) so the sprite
# reaches szproxy at http://127.0.0.1:<listen-port> with ZERO public exposure. Set
# an explicit reachable URL (e.g. a tailnet/proxy endpoint) to skip the tunnel.
# remote_base_url = ""   # "" or "auto" = reverse tunnel; or an explicit URL

# ── Local merge queue: the "fold-actor" (optional) ─────────────────────────
# Stop hand-sequencing parallel branches into main. The fold-actor folds every
# queued worktree branch onto `target_branch` entirely in the git object
# database (no checkout, milliseconds): branches that merge clean land
# automatically as sequential merge commits, and only genuine conflicts are
# deferred for you (or an agent) to resolve. Fire it once with `superzej
# integrate` / the palette action, or let `auto_drain` fold on agent-done.
#
# Because ten clean *textual* merges say nothing about whether their *union*
# builds, the fold is test-gated: the folded tip is checked out into a throwaway
# worktree, `gate_command` runs, and main only advances (atomic compare-and-swap)
# if it's green — bisecting the offending branch on red. This is the real
# correctness wall, automated rather than babysat.
#
# On by default; the core (fold + integrate) is AI-free — the agent handoff is
# the only AI touch and only fires on a conflict. Set enabled = false to remove
# the command, panel section, and badge entirely.
[merge_queue]
enabled = true
target_branch = "auto"        # branch to advance; "auto" = repo HEAD/default
gate_command = ""             # e.g. "just ci" / "cargo test --workspace"; "" disables the gate
gate_on = true                # run gate_command before advancing main
bisect_on_red = true          # on a red gate, defer just the offending branch
auto_drain = true             # fold automatically when an agent signals done
snapshot_dirty = false        # auto-commit uncommitted worktree work before folding
regenerate_paths = ["Cargo.lock"]  # conflicts confined to these are "regenerable", not handed off
regenerate_command = ""        # e.g. "cargo update --workspace"; rebuilds regenerate_paths to auto-land them ("" defers instead)
conflict_handoff = "agent"    # agent | notify | manual — fate of a deferred branch

# ── Time-travel replay (optional) ───────────────────────────────────────────
# Record each pane's full byte stream into a bounded in-memory ring so you can
# scrub a pane's history like a video (Alt+r): play/pause, step, seek, skip idle
# gaps — and search for any string that EVER appeared on screen, including inside
# full-screen apps (vim/htop) whose output never reaches scrollback. Distinct from
# the whole-session asciinema recorder (Ctrl+Alt+r), which writes a .cast file.
#
# On by default and bounded by BOTH a byte and a duration budget per pane; when
# enabled = false no ring is allocated and recording costs a single null check.
[replay]
enabled = true                 # master switch; false ⇒ zero cost, no recording
max_bytes_per_pane = 8388608    # per-pane ring byte budget (8 MiB); oldest events evicted past this
max_duration_secs = 1800        # per-pane time budget (30 m); older events evicted
keyframe_interval_ms = 4000     # capture a scrub-timeline marker after this much activity …
keyframe_interval_bytes = 262144 # … or after this many bytes, whichever first (256 KiB)
idle_threshold_ms = 1000        # during playback, gaps longer than this are collapsed (skip-inactivity)
persist = false                 # mirror rings to $XDG_STATE_HOME/superzej/replay/<session>/<pane>.szr for cross-restart scrubbing

# ── Media player control (optional) ────────────────────────────────────────
# Drive your music/media player from superzej: play/pause, next/previous,
# shuffle, loop, volume, and a playlist/player picker — plus a now-playing
# statusbar badge and panel section. The shell never depends on this; it is
# strictly additive.
#
# `backend = "auto"` (the default) picks the right backend for your OS:
#   • Linux   → MPRIS (org.mpris.MediaPlayer2) — native zbus, falling back to the
#               `playerctl` CLI. Controls Spotify, mpv (mpris plugin), ncspot,
#               spotify-player, musikcube, moc, VLC, cmus, … (install `playerctl`
#               if zbus can't reach your session bus).
#   • Windows → SMTC (System Media Transport Controls) — whatever app owns the
#               system media session (Spotify, browsers, Groove, …).
#   • macOS   → AppleScript via `osascript` — Music.app + Spotify.
# Force a specific backend with `mpris` / `smtc` / `applescript`, or `mpv` to
# drive a single mpv instance over its JSON IPC socket (see [media.mpv]).
# `jellyfin` is reserved. A backend selected on the wrong OS is simply inert.
#
# Only the selected backend's sub-table is consulted. On by default; it degrades
# to inert (no badge, no panel section, no watcher) wherever no supported player
# is reachable. Set enabled = false to remove the badge, the panel section, and
# make every media-* keybind inert — zero idle cost.
[media]
enabled = true
backend = "auto"            # auto | none | mpris | mpv | smtc | applescript | jellyfin
# Preferred players (MPRIS bus-name tails) when several are running at once; the
# first match wins. Empty = pick whatever is actively playing, else the first.
players_priority = []        # e.g. ["spotify", "mpv"]
# Reserved single "media key" action (each transport op already has its own
# bindable action id: media-play-pause, media-next, …).
default_action = "play_pause"  # play_pause | next | previous | volume_up | volume_down
# Volume step (0.0–1.0) for media-volume-up / media-volume-down.
volume_step = 0.05
# Fallback poll cadence (seconds) for backends WITHOUT a push stream (mpv IPC /
# playerctl). The native MPRIS path uses D-Bus PropertiesChanged signals
# instead, so this never fires for it (the ~0%-idle contract holds).
poll_interval_secs = 3

# [media.mpv]   # backend = "mpv": launch mpv with --input-ipc-server=<socket>
# socket = "/tmp/mpvsocket"
